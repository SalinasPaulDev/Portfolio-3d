<canvas id="background-canvas"></canvas>
<canvas id="foreground-canvas"></canvas>

<style>
    #background-canvas,
    #foreground-canvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
    }
    
    #background-canvas {
        z-index: -2;
        pointer-events: none;
    }
    
    #foreground-canvas {
        z-index: -1;
        pointer-events: none; /* Mantener none para no bloquear clics en el contenido */
    }
</style>

<script>
    // @ts-ignore
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
    import { EffectComposer } from 'three/examples/jsm/postprocessing/EffectComposer.js';
    import { RenderPass } from 'three/examples/jsm/postprocessing/RenderPass.js';
    import { UnrealBloomPass } from 'three/examples/jsm/postprocessing/UnrealBloomPass.js';
    import { BokehPass } from 'three/examples/jsm/postprocessing/BokehPass.js';
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Register the plugin
    gsap.registerPlugin(ScrollTrigger);

    // ============================================
    // TIPOS DE ANIMACIÓN PARA TRIÁNGULOS
    // ============================================
    enum AnimationType {
        CIRCULAR = 'circular',           // Movimiento circular en X-Y
        VERTICAL_WAVE = 'vertical_wave', // Sube y baja suavemente
        DIAGONAL = 'diagonal',           // Movimiento diagonal suave
        SPIRAL = 'spiral',               // Espiral suave
        DRIFT = 'drift'                  // Deriva lenta en múltiples ejes
    }

    // ============================================
    // CONFIGURACIÓN
    // ============================================
    // const PARTICLES_PER_EDGE = 10;
    const PARTICLES_PER_FACE = 30; // Aumentado de 100 a 300 para más densidad

    // ============================================
    // VARIABLES GLOBALES
    // ============================================
    // Background (triángulos con blur)
    let cameraBackground: THREE.PerspectiveCamera, sceneBackground: THREE.Scene, rendererBackground: THREE.WebGLRenderer;
    let composerBackground: EffectComposer;
    
    // Foreground (partículas sin blur)
    let cameraForeground: THREE.PerspectiveCamera, sceneForeground: THREE.Scene, rendererForeground: THREE.WebGLRenderer;
    let particleSystem: THREE.Group;
    let triangleParticles: Array<{
        object: THREE.Group;
        initialPosition: THREE.Vector3;
        rotationSpeed: THREE.Vector3;
        floatOffset: number;
        originalScale: number;
        currentScale: number;
        targetScale: number;
        originalColor: THREE.Color;
        originalEmissive: THREE.Color;
        originalEmissiveIntensity: number;
        originalObjectPosition: THREE.Vector3;
        originalObjectRotation: THREE.Vector3;
        originalObjectScale: number;
    }> = [];
    
    // Variables para interacción con el mouse
    const cameraTarget = new THREE.Vector3(0, 0, 0);
    const mousePosition = { x: 0, y: 0 };
    const targetMousePosition = { x: 0, y: 0 };
    const maxLookOffset = 0.01; // Reducido para limitar el rango de movimiento
    const mouseSensitivity = 0.001; // Muy reducido para movimiento sutil y pesado
    
    // Variables para el movimiento de los triángulos basado en el mouse
    const triangleMouseOffset = { x: 0, y: 0 };
    const targetTriangleMouseOffset = { x: 0, y: 0 };
    const triangleMouseSensitivity = 1.5; // Sensibilidad para el movimiento de triángulos
    
    // Variables para efecto hover en partículas
    const raycaster = new THREE.Raycaster();
    const mouse2D = new THREE.Vector2();
    const hoverRadius = 100; // Radio de influencia en píxeles
    let mouseScreenPosition = { x: 0, y: 0 };
    
    const floatingTriangles: Array<{
        object: THREE.Group;
        animationType: AnimationType;
        initialX: number;
        initialY: number;
        initialZ: number;
        circleRadius: number;
        circleSpeed: number;
        circleAngleOffset: number;
        verticalAmplitude: number;
        verticalSpeed: number;
        verticalOffset: number;
        depthAmplitude: number;
        depthSpeed: number;
        depthOffset: number;
        initialRotationX: number;
        initialRotationY: number;
        initialRotationZ: number;
        rotationSpeedX: number;
        rotationSpeedY: number;
        rotationSpeedZ: number;
        rotationAmplitudeX: number;
        rotationAmplitudeY: number;
        rotationAmplitudeZ: number;
        timeOffsetX: number;
        timeOffsetY: number;
        timeOffsetZ: number;
    }> = [];

    // ============================================
    // INICIALIZACIÓN
    // ============================================
    const canvasBackground = document.querySelector('#background-canvas');
    const canvasForeground = document.querySelector('#foreground-canvas');
    const body = document.querySelector('#main');
    let rotationByProgress: number = 0;

    // ============================================
    // SETUP BACKGROUND (triángulos con blur)
    // ============================================
    cameraBackground = new THREE.PerspectiveCamera(
        75,
        window.innerWidth / window.innerHeight,
        0.1,
        1000
    );
    cameraBackground.position.set(0, 0, 8);
    cameraBackground.lookAt(0, 0, 0);

    sceneBackground = new THREE.Scene();
    sceneBackground.background = new THREE.Color(0x000104);
    sceneBackground.fog = new THREE.FogExp2(0x000104, 0.08);

    rendererBackground = new THREE.WebGLRenderer({ 
        canvas: canvasBackground as HTMLCanvasElement,
        antialias: true
    });
    rendererBackground.setSize(window.innerWidth, window.innerHeight);
    rendererBackground.setPixelRatio(window.devicePixelRatio);

    // ============================================
    // SETUP FOREGROUND (partículas sin blur, fondo transparente)
    // ============================================
    cameraForeground = new THREE.PerspectiveCamera(
        75,
        window.innerWidth / window.innerHeight,
        0.1,
        1000
    );
    cameraForeground.position.set(0, 0, 8);
    cameraForeground.lookAt(0, 0, 0);

    sceneForeground = new THREE.Scene();
    // No background para transparencia

    rendererForeground = new THREE.WebGLRenderer({ 
        canvas: canvasForeground as HTMLCanvasElement,
        antialias: true,
        alpha: true // Importante para transparencia
    });
    rendererForeground.setSize(window.innerWidth, window.innerHeight);
    rendererForeground.setPixelRatio(window.devicePixelRatio);

    // ============================================
    // POST-PROCESSING (solo para background)
    // ============================================
    composerBackground = new EffectComposer(rendererBackground);
    
    const renderPass = new RenderPass(sceneBackground, cameraBackground);
    composerBackground.addPass(renderPass);
    
    const bloomPass = new UnrealBloomPass(
        new THREE.Vector2(window.innerWidth, window.innerHeight),
        0.4,
        0.4,
        0.95
    );
    composerBackground.addPass(bloomPass);

    const bokehPass = new BokehPass(sceneBackground, cameraBackground, {
        focus: 8.0,
        aperture: 0.035,
        maxblur: 0.003,
    });
    composerBackground.addPass(bokehPass);

    // ============================================
    // INTERACCIÓN CON EL MOUSE
    // ============================================
    document.addEventListener('mousemove', (event) => {
        const normalizedX = (event.clientX / window.innerWidth) * 2 - 1;
        const normalizedY = -(event.clientY / window.innerHeight) * 2 + 1;
        
        targetMousePosition.x = normalizedX * mouseSensitivity;
        targetMousePosition.y = normalizedY * mouseSensitivity;
        
        // Invertir el movimiento para los triángulos (opuesto al mouse)
        targetTriangleMouseOffset.x = -normalizedX * triangleMouseSensitivity;
        targetTriangleMouseOffset.y = -normalizedY * triangleMouseSensitivity;
        
        // Guardar posición del mouse en coordenadas de pantalla para el efecto hover
        mouseScreenPosition.x = event.clientX;
        mouseScreenPosition.y = event.clientY;
        
        // Actualizar coordenadas para raycaster
        mouse2D.x = normalizedX;
        mouse2D.y = normalizedY;
    });
    
    document.addEventListener('mouseleave', () => {
        targetMousePosition.x = 0;
        targetMousePosition.y = 0;
        targetTriangleMouseOffset.x = 0;
        targetTriangleMouseOffset.y = 0;
        mouseScreenPosition.x = -9999; // Fuera de pantalla
        mouseScreenPosition.y = -9999;
    });

    // ============================================
    // LUCES PARA BACKGROUND
    // ============================================
    const ambientLightBg = new THREE.AmbientLight(0xffffff, 0.8);
    sceneBackground.add(ambientLightBg);

    const pointLightBg = new THREE.PointLight(0xffffff, 1.5);
    pointLightBg.position.set(2, 1, 2);
    sceneBackground.add(pointLightBg);

    // ============================================
    // LUCES PARA FOREGROUND (más tenues para colores oscuros)
    // ============================================
    const ambientLightFg = new THREE.AmbientLight(0xffffff, 0.6);
    sceneForeground.add(ambientLightFg);

    // Luz direccional principal más tenue
    const directionalLightFg = new THREE.DirectionalLight(0xffffff, 0.9);
    directionalLightFg.position.set(5, 5, 8);
    sceneForeground.add(directionalLightFg);

    // Luz de relleno muy sutil
    const fillLightFg = new THREE.DirectionalLight(0xffffff, 0.4);
    fillLightFg.position.set(-3, 0, -2);
    sceneForeground.add(fillLightFg);

    // Luz directa centrada para iluminar dev.glb
    const spotLightFg = new THREE.DirectionalLight(0xffd700, 12.0);
    spotLightFg.position.set(2, 2, 8); // Más centrada, cerca de la cámara
    spotLightFg.target.position.set(0, 0, 0); // Apunta al centro
    sceneForeground.add(spotLightFg);
    sceneForeground.add(spotLightFg.target);

    // ============================================
    // CARGAR MODELO PRINCIPAL Y TRIÁNGULOS PARA PARTÍCULAS
    // ============================================
    const loader = new GLTFLoader();
    
    let triangleTemplate: THREE.Group | null = null;
    const trianglesColors = [
        0x96F7D2,  // Turquesa
        0xFFD700,  // Amarillo dorado
        0xFFA500,  // Naranja
        0xFFF1F1,  // Blanco rosado
        0x6F00FF,  // Morado
        0xFF69B4   // Rosa
    ];
    
    // Primero cargamos el triángulo que usaremos como partícula
    loader.load('/triangles/py-lod7.glb', function(gltf) {
        triangleTemplate = gltf.scene;
        console.log('✅ Triángulo cargado para partículas');
        
        // Ahora cargamos el modelo principal para generar posiciones
        loader.load(
            '/dev.glb',
            function(gltf) {            
                gltf.scene.scale.setScalar(0.2);
                gltf.scene.position.set(0, 0, 0);
                
                const positions = generateEdgeParticles(gltf.scene);
                
                if (positions.count === 0) {
                    console.error('❌ No se encontraron vértices');
                    return;
                }
                
                console.log(`📊 Partículas generadas: ${positions.count}`);
                
                if (triangleTemplate) {
                    createTriangleParticleSystem(positions, triangleTemplate);
                }
            },
            function(xhr) {
                const percent = (xhr.loaded / xhr.total) * 100;
                console.log(`⏳ Cargando dev-test.glb: ${percent.toFixed(2)}%`);
            },
            function(error) {
                console.error('❌ Error al cargar:', error);
            }
        );
    });

    // ============================================
    // CARGAR TRIÁNGULOS FLOTANTES
    // ============================================
    loader.load('/triangles/py-lod7.glb', function(gltf) {
        const trianglesColors = [0x96F7D2, 0xFFE100, 0xFFF1F1, 0x6F00FF];

        const count = 900; // Cantidad de triángulos
        
        // Distribución esférica CENTRADA EN LA CÁMARA
        // Así rodea la cámara en todas direcciones sin espacios vacíos
        const cameraX = 0;     // Posición X de la cámara
        const cameraY = 0;     // Posición Y de la cámara  
        const cameraZ = 8;     // Posición Z de la cámara
        const minRadius = 10;  // Radio mínimo (triángulos más cerca)
        const maxRadius = 35;  // Radio máximo (triángulos más lejos)
        
        // Tipos de animación disponibles
        const animationTypes = Object.values(AnimationType);
        
        for (let i = 0; i < count; i++) {
            const clone = gltf.scene.clone();
            clone.scale.setScalar(Math.random() * 0.3 + 0.25);
            
            // Distribución esférica uniforme usando Fibonacci/Golden Ratio
            const goldenRatio = (1 + Math.sqrt(5)) / 2;
            const theta = 2 * Math.PI * i / goldenRatio; // Ángulo horizontal (0 a 2*PI)
            const phi = Math.acos(1 - 2 * (i + 0.5) / count); // Ángulo vertical (0 a PI)
            
            // Radio aleatorio para crear capas de profundidad
            const radius = minRadius + Math.random() * (maxRadius - minRadius);
            
            // Convertir coordenadas esféricas a cartesianas, CENTRADO EN LA CÁMARA
            const baseX = cameraX + radius * Math.sin(phi) * Math.cos(theta);
            const baseY = cameraY + radius * Math.cos(phi);
            const baseZ = cameraZ + radius * Math.sin(phi) * Math.sin(theta);
            
            // Pequeño offset aleatorio para más naturalidad
            const randomOffset = 1.5;
            const offsetX = (Math.random() - 0.5) * randomOffset;
            const offsetY = (Math.random() - 0.5) * randomOffset;
            const offsetZ = (Math.random() - 0.5) * randomOffset * 2;
            
            const finalX = baseX + offsetX;
            const finalY = baseY + offsetY;
            const finalZ = baseZ + offsetZ;
            clone.position.set(finalX, finalY, finalZ);
            
            const initialRotX = Math.random() * Math.PI * 2;
            const initialRotY = Math.random() * Math.PI * 2;
            const initialRotZ = Math.random() * Math.PI * 2;
            clone.rotation.set(initialRotX, initialRotY, initialRotZ);
            
            // Asignar tipo de animación aleatorio
            const randomAnimationType = animationTypes[Math.floor(Math.random() * animationTypes.length)];
            
            const distanceFromCamera = cameraBackground.position.distanceTo(clone.position);
            const minDistance = 5;
            const maxDistance = 20;
            const normalizedDistance = Math.max(0, Math.min(1, (distanceFromCamera - minDistance) / (maxDistance - minDistance)));
            
            const opacity = 1 - (normalizedDistance * 0.25);
            const brightness = 1 - (normalizedDistance * 0.2);
            
            const baseColor = trianglesColors[Math.floor(Math.random() * trianglesColors.length)];
            const color = new THREE.Color(baseColor);
            
            if (normalizedDistance > 0.6) {
                color.multiplyScalar(brightness);
            }
            
            const material = new THREE.MeshStandardMaterial({
                color: trianglesColors[Math.floor(Math.random() * trianglesColors.length)],
                emissive: trianglesColors[Math.floor(Math.random() * trianglesColors.length)],
                emissiveIntensity: opacity,
                metalness: 0.8,
                roughness: 0.2
            });
            
            clone.traverse((child) => {
                if ((child as THREE.Mesh).isMesh) {
                    (child as THREE.Mesh).material = material.clone();
                }
            });
            
            // Parámetros de animación más variados y suaves
            const rotSpeedX = 0.08 + Math.random() * 0.15;
            const rotSpeedY = 0.08 + Math.random() * 0.15;
            const rotSpeedZ = 0.08 + Math.random() * 0.15;
            
            const rotAmpX = 0.2 + Math.random() * 0.5;
            const rotAmpY = 0.2 + Math.random() * 0.5;
            const rotAmpZ = 0.2 + Math.random() * 0.5;
            
            const circleRadius = 0.2 + Math.random() * 0.6;
            const circleSpeed = 0.08 + Math.random() * 0.15;
            const circleAngleOffset = Math.random() * Math.PI * 2;
            
            const verticalAmplitude = 0.5 + Math.random() * 1.5;
            const verticalSpeed = 0.1 + Math.random() * 0.2;
            const verticalOffset = Math.random() * Math.PI * 2;
            
            const depthAmplitude = 0.3 + Math.random() * 0.8;
            const depthSpeed = 0.07 + Math.random() * 0.13;
            const depthOffset = Math.random() * Math.PI * 2;
            
            const timeOffsetX = Math.random() * Math.PI * 2;
            const timeOffsetY = Math.random() * Math.PI * 2;
            const timeOffsetZ = Math.random() * Math.PI * 2;
            
            floatingTriangles.push({
                object: clone,
                animationType: randomAnimationType,
                initialX: finalX,
                initialY: finalY,
                initialZ: finalZ,
                circleRadius: circleRadius,
                circleSpeed: circleSpeed,
                circleAngleOffset: circleAngleOffset,
                verticalAmplitude: verticalAmplitude,
                verticalSpeed: verticalSpeed,
                verticalOffset: verticalOffset,
                depthAmplitude: depthAmplitude,
                depthSpeed: depthSpeed,
                depthOffset: depthOffset,
                initialRotationX: initialRotX,
                initialRotationY: initialRotY,
                initialRotationZ: initialRotZ,
                rotationSpeedX: rotSpeedX,
                rotationSpeedY: rotSpeedY,
                rotationSpeedZ: rotSpeedZ,
                rotationAmplitudeX: rotAmpX,
                rotationAmplitudeY: rotAmpY,
                rotationAmplitudeZ: rotAmpZ,
                timeOffsetX: timeOffsetX,
                timeOffsetY: timeOffsetY,
                timeOffsetZ: timeOffsetZ
            });
            
            sceneBackground.add(clone);
        }
    });

    // ============================================
    // GENERAR PARTÍCULAS EN CARAS
    // ============================================
    function generateEdgeParticles(object: THREE.Object3D): THREE.BufferAttribute {
        const allPoints: number[] = [];
        let faceCount = 0;

        object.traverse(function(child) {
            if ((child as THREE.Mesh).isMesh && (child as THREE.Mesh).geometry) {
                const mesh = child as THREE.Mesh;
                const geometry = mesh.geometry;
                const positions = geometry.attributes.position;
                const index = geometry.index;
                
                if (!positions) return;

                const matrix = mesh.matrixWorld;

                const indices = index ? index.array : null;
                const positionCount = positions.count;
                
                if (indices) {
                    for (let i = 0; i < indices.length; i += 3) {
                        faceCount++;
                        
                        const i1 = indices[i];
                        const i2 = indices[i + 1];
                        const i3 = indices[i + 2];
                        
                        const v1 = new THREE.Vector3(
                            positions.getX(i1),
                            positions.getY(i1),
                            positions.getZ(i1)
                        ).applyMatrix4(matrix);
                        
                        const v2 = new THREE.Vector3(
                            positions.getX(i2),
                            positions.getY(i2),
                            positions.getZ(i2)
                        ).applyMatrix4(matrix);
                        
                        const v3 = new THREE.Vector3(
                            positions.getX(i3),
                            positions.getY(i3),
                            positions.getZ(i3)
                        ).applyMatrix4(matrix);
                        
                        sampleFace(v1, v2, v3, allPoints, PARTICLES_PER_FACE);
                    }
                } else {
                    for (let i = 0; i < positionCount; i += 3) {
                        faceCount++;
                        
                        const v1 = new THREE.Vector3(
                            positions.getX(i),
                            positions.getY(i),
                            positions.getZ(i)
                        ).applyMatrix4(matrix);
                        
                        const v2 = new THREE.Vector3(
                            positions.getX(i + 1),
                            positions.getY(i + 1),
                            positions.getZ(i + 1)
                        ).applyMatrix4(matrix);
                        
                        const v3 = new THREE.Vector3(
                            positions.getX(i + 2),
                            positions.getY(i + 2),
                            positions.getZ(i + 2)
                        ).applyMatrix4(matrix);
                        
                        sampleFace(v1, v2, v3, allPoints, PARTICLES_PER_FACE);
                    }
                }
            }
        });

        console.log(`🔺 Total de caras: ${faceCount}`);
        console.log(`✨ Partículas por cara: ${PARTICLES_PER_FACE}`);
        
        if (allPoints.length === 0) {
            return new THREE.BufferAttribute(new Float32Array(0), 3);
        }
        
        return new THREE.BufferAttribute(new Float32Array(allPoints), 3);
    }

    // ============================================
    // SAMPLEAR PUNTOS EN CARAS
    // ============================================
    function sampleFace(
        v1: THREE.Vector3,
        v2: THREE.Vector3,
        v3: THREE.Vector3,
        points: number[],
        count: number
    ): void {
        for (let i = 0; i < count; i++) {
            let r1 = Math.random();
            let r2 = Math.random();
            
            if (r1 + r2 > 1) {
                r1 = 1 - r1;
                r2 = 1 - r2;
            }
            
            const r3 = 1 - r1 - r2;
            
            const point = new THREE.Vector3();
            point.addScaledVector(v1, r1);
            point.addScaledVector(v2, r2);
            point.addScaledVector(v3, r3);
            
            points.push(point.x, point.y, point.z);
        }
    }

    // ============================================
    // CREAR SISTEMA DE PARTÍCULAS CON TRIÁNGULOS
    // ============================================
    function createTriangleParticleSystem(positions: THREE.BufferAttribute, template: THREE.Group) {
        particleSystem = new THREE.Group();
        
        // Aplicar transformaciones al grupo principal
        particleSystem.scale.setScalar(3.5);
        particleSystem.position.set(5, 0, 0);
        
        const particleCount = positions.count;
        const skipFactor = 1; // Usar todas las posiciones para máxima densidad
        
        for (let i = 0; i < particleCount; i += skipFactor) {
            const clone = template.clone();
            
            // Tamaño más pequeño y uniforme (como en Dala)
            const scale = 0.018 + Math.random() * 0.008; // Más uniforme
            clone.scale.setScalar(scale);
            
            // Posición desde los datos generados
            const x = positions.getX(i);
            const y = positions.getY(i);
            const z = positions.getZ(i);
            clone.position.set(x, y, z);
            
            // Rotación inicial aleatoria
            clone.rotation.set(
                Math.random() * Math.PI * 2,
                Math.random() * Math.PI * 2,
                Math.random() * Math.PI * 2
            );
            
            // GRADIENTE HORIZONTAL (izquierda a derecha)
            // Normalizar la posición X para crear un gradiente horizontal
            // Izquierda (X bajo) = Morado oscuro
            // Derecha (X alto) = Amarillo claro
            
            // Normalizar X entre 0 y 1 (asumiendo rango aproximado de -2 a 2)
            const normalizedX = (x + 2) / 4; // Ajusta según el rango de tu modelo
            
            // Definir colores del gradiente (más oscuros)
            // Orden: morado → azul → rosa → naranja → amarillo → amarillo claro
            const color1 = new THREE.Color(0x4A0080);      // Morado oscuro (izquierda)
            const color2 = new THREE.Color(0x5A00B8);      // Morado más claro
            const color3 = new THREE.Color(0x0066CC);      // Azul oscuro
            const color4 = new THREE.Color(0xCC3399);      // Rosa oscuro
            const color5 = new THREE.Color(0xD96B00);      // Naranja oscuro
            const color6 = new THREE.Color(0xFF9900);      // Naranja
            const color7 = new THREE.Color(0xFFB700);      // Amarillo dorado
            const color8 = new THREE.Color(0xFFD740);      // Amarillo claro (derecha)
            
            let baseColor: THREE.Color;
            
            // Crear gradiente suave con múltiples stops
            if (normalizedX < 0.14) {
                // Zona 1: Morado oscuro a Morado claro
                const t = normalizedX / 0.14;
                baseColor = color1.clone().lerp(color2, t);
            } else if (normalizedX < 0.28) {
                // Zona 2: Morado a Azul
                const t = (normalizedX - 0.14) / 0.14;
                baseColor = color2.clone().lerp(color3, t);
            } else if (normalizedX < 0.42) {
                // Zona 3: Azul a Rosa
                const t = (normalizedX - 0.28) / 0.14;
                baseColor = color3.clone().lerp(color4, t);
            } else if (normalizedX < 0.57) {
                // Zona 4: Rosa a Naranja oscuro
                const t = (normalizedX - 0.42) / 0.15;
                baseColor = color4.clone().lerp(color5, t);
            } else if (normalizedX < 0.71) {
                // Zona 5: Naranja oscuro a Naranja
                const t = (normalizedX - 0.57) / 0.14;
                baseColor = color5.clone().lerp(color6, t);
            } else if (normalizedX < 0.85) {
                // Zona 6: Naranja a Amarillo dorado
                const t = (normalizedX - 0.71) / 0.14;
                baseColor = color6.clone().lerp(color7, t);
            } else {
                // Zona 7: Amarillo dorado a Amarillo claro
                const t = (normalizedX - 0.85) / 0.15;
                baseColor = color7.clone().lerp(color8, t);
            }
            
            // Añadir variación sutil aleatoria para naturalidad (muy poca)
            const randomVariation = (Math.random() - 0.5) * 0.08;
            baseColor.offsetHSL(0, 0, randomVariation);
            
            // Brillo más oscuro en general
            const brightness = 0.6 + normalizedX * 0.35; // 0.6 a 0.95 (más oscuro)
            baseColor.multiplyScalar(brightness);
            
            // Emisividad basada en posición
            const emissiveColor = baseColor.clone().multiplyScalar(0.7); // Reducido de 1.2 a 0.7
            const emissiveIntensity = 0.6 + normalizedX * 0.3; // Reducido para menos brillo
            
            const material = new THREE.MeshStandardMaterial({
                color: baseColor,
                emissive: emissiveColor,
                emissiveIntensity: emissiveIntensity,
                metalness: 0.6 + Math.random() * 0.2,
                roughness: 0.25 + Math.random() * 0.15,
                transparent: true,
                opacity: 0.9 + Math.random() * 0.1,
                envMapIntensity: 0.6
            });
            
            clone.traverse((child) => {
                if ((child as THREE.Mesh).isMesh) {
                    (child as THREE.Mesh).material = material.clone();
                }
            });
            
            // Guardar datos de animación con valores originales para animaciones de dispersión
            triangleParticles.push({
                object: clone,
                initialPosition: new THREE.Vector3(x, y, z),
                rotationSpeed: new THREE.Vector3(
                    0.005 + Math.random() * 0.008,  // Mucho más lento
                    0.005 + Math.random() * 0.008,
                    0.005 + Math.random() * 0.008
                ),
                floatOffset: Math.random() * Math.PI * 2,
                originalScale: scale,
                currentScale: scale,
                targetScale: scale,
                originalColor: baseColor.clone(),
                originalEmissive: emissiveColor.clone(),
                originalEmissiveIntensity: emissiveIntensity,
                // Guardar valores originales de la partícula para dispersión
                originalObjectPosition: new THREE.Vector3(clone.position.x, clone.position.y, clone.position.z),
                originalObjectRotation: new THREE.Vector3(clone.rotation.x, clone.rotation.y, clone.rotation.z),
                originalObjectScale: clone.scale.x
            });
            
            particleSystem.add(clone);
        }
        
        sceneForeground.add(particleSystem);
        
        console.log(`✨ Sistema de ${triangleParticles.length} triángulos creado en canvas foreground`);
        
        // Configurar animación de scroll
        const initScrollAnimations = () => {
            const introSection = document.querySelector('#introduction');
            const aboutSection = document.querySelector('#about');
            
            // Los valores iniciales ya están establecidos en createTriangleParticleSystem:
            // particleSystem.position.x = 5
            // particleSystem.rotation.y = 0
            // cameraBackground.position.x = 0 (establecido en setup)
            // cameraForeground.position = (0, 0, 8) (establecido en setup)
            
            if (introSection) {
            // ============================================
            // SECCIÓN 1 → 2: Movimiento y rotación
            // ============================================
            
            // Mover el objeto de derecha a izquierda
            ScrollTrigger.create({
                trigger: '#main',
                start: 'top top',
                endTrigger: '#introduction',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    // Interpolar de 5 a -5
                    particleSystem.position.x = 5 - (self.progress * 10);
                }
            });
            
            // Rotar el objeto 180 grados
            ScrollTrigger.create({
                trigger: '#main',
                start: 'top top',
                endTrigger: '#introduction',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    // Interpolar de 0 a PI
                    particleSystem.rotation.y = self.progress * Math.PI;
                }
            });
            
            // Mover la cámara del background para efecto parallax (sección 1)
            ScrollTrigger.create({
                trigger: '#main',
                start: 'top top',
                endTrigger: '#introduction',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    // Interpolar de 0 a 3
                    cameraBackground.position.x = self.progress * 3;
                }
            });
        }
        
        if (aboutSection) {
            // ============================================
            // SECCIÓN 2 → 3: Desintegración y dispersión
            // ============================================
            
            // Mover la cámara del foreground
            ScrollTrigger.create({
                trigger: '#introduction',
                start: 'bottom bottom',
                endTrigger: '#about',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    // Interpolar z de 8 a 6
                    cameraForeground.position.z = 8 - (self.progress * 2);
                }
            });
            
            // Mover la cámara del background (parallax) - sección 2
            ScrollTrigger.create({
                trigger: '#introduction',
                start: 'bottom bottom',
                endTrigger: '#about',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    // Interpolar de 3 a 4
                    cameraBackground.position.x = 3 + self.progress;
                }
            });
            
            // Preparar datos de animación para cada partícula
            // Generar datos aleatorios una vez y guardarlos
            const particleAnimData = triangleParticles.map((particle) => {
                const particleY = particle.initialPosition.y;
                const normalizedY = (particleY + 1) / 2;
                const delayStart = normalizedY * 0.6;
                const delayEnd = normalizedY * 0.6 + 0.4;
                
                // Valores aleatorios fijos para esta partícula
                const disperseX = (Math.random() - 0.5) * 8;
                const disperseY = (Math.random() - 0.5) * 6;
                
                const depthVariation = Math.random();
                let disperseZ;
                if (depthVariation < 0.3) {
                    disperseZ = -(2 + Math.random() * 1);
                } else if (depthVariation < 0.6) {
                    disperseZ = -(1 + Math.random() * 1);
                } else {
                    disperseZ = -(0 + Math.random() * 1);
                }
                
                let scaleFactor;
                if (depthVariation < 0.3) {
                    scaleFactor = 0.06 + Math.random() * 0.04;
                } else if (depthVariation < 0.6) {
                    scaleFactor = 0.04 + Math.random() * 0.04;
                } else {
                    scaleFactor = 0.03 + Math.random() * 0.03;
                }
                scaleFactor = Math.min(scaleFactor, 0.08);
                
                const randomRotation = Math.random() * Math.PI * 4;
                
                return {
                    particle,
                    delayStart,
                    delayEnd,
                    // Valores originales fijos desde el momento de creación
                    startX: particle.originalObjectPosition.x,
                    startY: particle.originalObjectPosition.y,
                    startZ: particle.originalObjectPosition.z,
                    startScale: particle.originalObjectScale,
                    startRotX: particle.originalObjectRotation.x,
                    startRotY: particle.originalObjectRotation.y,
                    startRotZ: particle.originalObjectRotation.z,
                    // Valores finales calculados una vez
                    endX: particle.originalObjectPosition.x + disperseX,
                    endY: particle.originalObjectPosition.y + disperseY,
                    endZ: particle.originalObjectPosition.z + disperseZ,
                    endScale: particle.originalObjectScale * scaleFactor,
                    rotationDelta: randomRotation
                };
            });
            
            // Un solo ScrollTrigger para todas las partículas (más eficiente)
            ScrollTrigger.create({
                trigger: '#introduction',
                start: 'bottom bottom',
                endTrigger: '#about',
                end: 'bottom bottom',
                scrub: true,
                onUpdate: (self) => {
                    const globalProgress = self.progress;
                    
                    particleAnimData.forEach((data) => {
                        // Calcular progreso local basado en delay
                        const localStart = data.delayStart;
                        const localEnd = data.delayEnd;
                        const localProgress = Math.max(0, Math.min(1, 
                            (globalProgress - localStart) / (localEnd - localStart)
                        ));
                        
                        // SIEMPRE actualizar, incluso cuando localProgress es 0 para resetear correctamente
                        // Posición
                        data.particle.object.position.x = data.startX + (data.endX - data.startX) * localProgress;
                        data.particle.object.position.y = data.startY + (data.endY - data.startY) * localProgress;
                        data.particle.object.position.z = data.startZ + (data.endZ - data.startZ) * localProgress;
                        
                        // Escala
                        const scale = data.startScale + (data.endScale - data.startScale) * localProgress;
                        data.particle.object.scale.setScalar(scale);
                        
                        // Rotación
                        data.particle.object.rotation.x = data.startRotX + data.rotationDelta * localProgress;
                        data.particle.object.rotation.y = data.startRotY + data.rotationDelta * localProgress;
                        data.particle.object.rotation.z = data.startRotZ + data.rotationDelta * localProgress;
                    });
                }
            });
        }

        // ============================================
        // Objeto "dev": salida hacia atrás de la cámara al entrar a #experience
        // ============================================
        ScrollTrigger.create({
            trigger: '#projects',
            start: 'top top',
            endTrigger: '#experience',
            end: 'top top',
            scrub: true,
            onUpdate: (self) => {
                if (particleSystem) {
                    // Cámara foreground en z=8; empujamos el grupo hasta z=20 para dejarlo detrás
                    particleSystem.position.z = self.progress * 20;
                }
            }
        });
        };

        // Inicializar ScrollTrigger
        initScrollAnimations();
        
        // Refrescar para calcular posiciones y sincronizar con scroll actual
        ScrollTrigger.refresh();
    }

    // ============================================
    // ANIMACIÓN
    // ============================================
    let time = 0;
    let isFirstFrame = true; // Flag para el primer frame
    // Delta-time clock: at a steady 60fps, getDelta() ≈ 0.01667, so multiplying
    // by 0.72 yields ~0.012 per frame — identical to the previous fixed step.
    // On slower frames the increment scales up, so motion stays smooth instead
    // of appearing frozen during scroll-induced frame drops.
    const animClock = new THREE.Clock();
    // Cap delta to avoid huge jumps after tab-switch / long frames (e.g., 1s
    // pause shouldn't advance animation by 1s worth of motion).
    const MAX_DELTA = 1 / 20; // ~50ms, equivalent to 20fps floor

    function animate() {
        requestAnimationFrame(animate);
        const rawDelta = animClock.getDelta();
        const delta = rawDelta > MAX_DELTA ? MAX_DELTA : rawDelta;
        time += delta * 0.72;
        
        // En el primer frame, ya no necesitamos ajustar porque la posición se calcula
        // correctamente en initScrollAnimations basándose en el scroll actual
        if (isFirstFrame) {
            isFirstFrame = false;
        }
        
        const lerpFactor = 0.003; // Muy reducido para movimiento pesado y sutil de la cámara
        mousePosition.x += (targetMousePosition.x - mousePosition.x) * lerpFactor;
        mousePosition.y += (targetMousePosition.y - mousePosition.y) * lerpFactor;
        
        // Interpolación suave (ease-in-out) para el offset de los triángulos
        const triangleLerpFactor = 0.05; // Factor más alto para respuesta más rápida pero suave
        triangleMouseOffset.x += (targetTriangleMouseOffset.x - triangleMouseOffset.x) * triangleLerpFactor;
        triangleMouseOffset.y += (targetTriangleMouseOffset.y - triangleMouseOffset.y) * triangleLerpFactor;
        
        // Animar luces direccionales para crear efecto de gradiente dinámico
        updateDynamicLights();
        
        updateCameraLookAt();
        
        if (particleSystem) {
            updateParticles();
        }
        
        updateFloatingTriangles();
        
        // Renderizar background canvas (triángulos con blur)
        composerBackground.render();
        
        // Renderizar foreground canvas (partículas sin blur, fondo transparente)
        rendererForeground.render(sceneForeground, cameraForeground);
    }
    
    function updateDynamicLights() {
        // Animación MUY sutil de la luz (casi imperceptible)
        const lightSpeed = 0.1;
        const lightRadius = 1.5;
        
        directionalLightFg.position.x = 5 + Math.cos(time * lightSpeed) * lightRadius;
        directionalLightFg.position.y = 5 + Math.sin(time * lightSpeed * 0.7) * 0.8;
        directionalLightFg.position.z = 8 + Math.sin(time * lightSpeed) * lightRadius;
        
        // Variar intensidad muy sutilmente
        directionalLightFg.intensity = 0.9 + Math.sin(time * 0.15) * 0.15;
    }
    
    function updateCameraLookAt() {
        const offsetX = mousePosition.x * maxLookOffset;
        const offsetY = mousePosition.y * maxLookOffset;
        
        cameraTarget.x = 0 + offsetX;
        cameraTarget.y = 0 + offsetY; // Mirar más abajo (0 en vez de 2)
        cameraTarget.z = 0;
        
        // Actualizar ambas cámaras
        cameraBackground.lookAt(cameraTarget);
        cameraForeground.lookAt(cameraTarget);
    }
    
    function updateFloatingTriangles() {
        floatingTriangles.forEach((triangle) => {
            let floatX = triangle.initialX;
            let floatY = triangle.initialY;
            let floatZ = triangle.initialZ;
            
            // Diferentes tipos de animación
            switch(triangle.animationType) {
                case AnimationType.CIRCULAR:
                    const circleAngle = time * triangle.circleSpeed + triangle.circleAngleOffset;
                    floatX = triangle.initialX + Math.cos(circleAngle) * triangle.circleRadius;
                    floatY = triangle.initialY + Math.sin(circleAngle) * triangle.circleRadius;
                    floatZ = triangle.initialZ + Math.sin(time * triangle.depthSpeed + triangle.depthOffset) * (triangle.depthAmplitude * 0.3);
                    break;
                
                case AnimationType.VERTICAL_WAVE:
                    floatY = triangle.initialY + Math.sin(time * triangle.verticalSpeed + triangle.verticalOffset) * triangle.verticalAmplitude;
                    floatX = triangle.initialX + Math.cos(time * triangle.circleSpeed * 0.5 + triangle.circleAngleOffset) * (triangle.circleRadius * 0.4);
                    floatZ = triangle.initialZ + Math.sin(time * triangle.depthSpeed + triangle.depthOffset) * (triangle.depthAmplitude * 0.5);
                    break;
                
                case AnimationType.DIAGONAL:
                    const diagPhase = time * triangle.circleSpeed + triangle.circleAngleOffset;
                    floatX = triangle.initialX + Math.sin(diagPhase) * triangle.circleRadius;
                    floatY = triangle.initialY + Math.cos(diagPhase * 0.7) * triangle.verticalAmplitude * 0.6;
                    floatZ = triangle.initialZ + Math.sin(time * triangle.depthSpeed + triangle.depthOffset) * triangle.depthAmplitude;
                    break;
                
                case AnimationType.SPIRAL:
                    const spiralAngle = time * triangle.circleSpeed + triangle.circleAngleOffset;
                    const spiralRadius = triangle.circleRadius * (1 + Math.sin(time * triangle.verticalSpeed * 0.5 + triangle.verticalOffset) * 0.3);
                    floatX = triangle.initialX + Math.cos(spiralAngle) * spiralRadius;
                    floatY = triangle.initialY + Math.sin(time * triangle.verticalSpeed + triangle.verticalOffset) * triangle.verticalAmplitude * 0.5;
                    floatZ = triangle.initialZ + Math.sin(spiralAngle * 0.5) * triangle.depthAmplitude;
                    break;
                
                case AnimationType.DRIFT:
                    floatX = triangle.initialX + 
                        Math.sin(time * triangle.circleSpeed * 0.3 + triangle.circleAngleOffset) * triangle.circleRadius * 0.7 +
                        Math.cos(time * triangle.circleSpeed * 0.5 + triangle.timeOffsetX) * triangle.circleRadius * 0.3;
                    
                    floatY = triangle.initialY + 
                        Math.sin(time * triangle.verticalSpeed * 0.4 + triangle.verticalOffset) * triangle.verticalAmplitude * 0.4 +
                        Math.cos(time * triangle.verticalSpeed * 0.6 + triangle.timeOffsetY) * triangle.verticalAmplitude * 0.3;
                    
                    floatZ = triangle.initialZ + 
                        Math.sin(time * triangle.depthSpeed + triangle.depthOffset) * triangle.depthAmplitude * 0.6 +
                        Math.cos(time * triangle.depthSpeed * 1.3 + triangle.timeOffsetZ) * triangle.depthAmplitude * 0.4;
                    break;
            }
            
            // Aplicar el offset del mouse (invertido) a las posiciones de los triángulos
            const finalX = floatX + triangleMouseOffset.x;
            const finalY = floatY + triangleMouseOffset.y;
            const finalZ = floatZ; // No aplicamos offset en Z para mantener la profundidad
            
            triangle.object.position.set(finalX, finalY, finalZ);
            
            // Rotaciones más suaves y variadas
            triangle.object.rotation.x = triangle.initialRotationX + 
                Math.sin(time * triangle.rotationSpeedX + triangle.timeOffsetX) * triangle.rotationAmplitudeX +
                Math.cos(time * triangle.rotationSpeedX * 0.5 + triangle.timeOffsetX * 1.5) * triangle.rotationAmplitudeX * 0.3;
            
            triangle.object.rotation.y = triangle.initialRotationY + 
                Math.cos(time * triangle.rotationSpeedY + triangle.timeOffsetY) * triangle.rotationAmplitudeY +
                Math.sin(time * triangle.rotationSpeedY * 0.7 + triangle.timeOffsetY * 0.8) * triangle.rotationAmplitudeY * 0.4;
            
            triangle.object.rotation.z = triangle.initialRotationZ + 
                Math.sin(time * triangle.rotationSpeedZ + triangle.timeOffsetZ) * triangle.rotationAmplitudeZ +
                Math.cos(time * triangle.rotationSpeedZ * 1.2 + triangle.timeOffsetZ * 0.6) * triangle.rotationAmplitudeZ * 0.25;
        });
    }

    function updateParticles() {
        // La rotación del particleSystem ahora es controlada por GSAP ScrollTrigger
        // particleSystem.rotation.y = rotationByProgress * Math.PI * 2;
        
        // Animar cada triángulo individualmente
        triangleParticles.forEach((particle) => {
            // Rotación continua
            particle.object.rotation.x += particle.rotationSpeed.x;
            particle.object.rotation.y += particle.rotationSpeed.y;
            particle.object.rotation.z += particle.rotationSpeed.z;
            
            // Pequeño movimiento flotante
            const floatAmount = Math.sin(time * 0.5 + particle.floatOffset) * 0.02;
            particle.object.position.y = particle.initialPosition.y + floatAmount;
            
            // ============================================
            // EFECTO HOVER CON EL MOUSE
            // ============================================
            // Convertir posición 3D de la partícula a coordenadas de pantalla 2D
            const worldPosition = new THREE.Vector3();
            particle.object.getWorldPosition(worldPosition);
            
            // Clonar para no modificar el original
            const screenPosition = worldPosition.clone();
            screenPosition.project(cameraForeground);
            
            // Convertir de coordenadas normalizadas (-1 a 1) a píxeles de pantalla
            const screenX = (screenPosition.x * 0.5 + 0.5) * window.innerWidth;
            const screenY = (-(screenPosition.y) * 0.5 + 0.5) * window.innerHeight;
            
            // Calcular distancia del mouse a la partícula en píxeles
            const dx = mouseScreenPosition.x - screenX;
            const dy = mouseScreenPosition.y - screenY;
            const distance = Math.sqrt(dx * dx + dy * dy);
            
            // Si la partícula está dentro del radio de influencia del mouse
            if (distance < hoverRadius) {
                // Calcular factor de influencia (1 = centro, 0 = borde del radio)
                const influence = 1 - (distance / hoverRadius);
                const smoothInfluence = influence * influence; // Suavizar la transición
                
                // Calcular distancia de la partícula a la cámara para limitar el scale
                const distanceToCamera = worldPosition.distanceTo(cameraForeground.position);
                
                // Partículas cercanas (< 4 unidades) tienen multiplicador reducido
                // Partículas lejanas (> 10 unidades) tienen multiplicador completo
                const minDist = 4;
                const maxDist = 10;
                const distanceFactor = Math.max(0.15, Math.min(1, (distanceToCamera - minDist) / (maxDist - minDist)));
                
                // Escala aumentada pero limitada por distancia a la cámara
                const baseMultiplier = 2.0 + smoothInfluence * 4.0;
                const scaleMultiplier = 1 + (baseMultiplier - 1) * distanceFactor;
                particle.targetScale = particle.originalScale * scaleMultiplier;
            } else {
                // Volver al tamaño original
                particle.targetScale = particle.originalScale;
            }
            
            // Interpolar suavemente hacia el tamaño objetivo
            const scaleLerpFactor = 0.15;
            particle.currentScale += (particle.targetScale - particle.currentScale) * scaleLerpFactor;
            particle.object.scale.setScalar(particle.currentScale);
            
            // Aplicar efecto de color más claro en hover
            particle.object.traverse((child) => {
                if ((child as THREE.Mesh).isMesh) {
                    const mesh = child as THREE.Mesh;
                    const material = mesh.material as THREE.MeshStandardMaterial;
                    
                    if (distance < hoverRadius) {
                        const influence = 1 - (distance / hoverRadius);
                        const smoothInfluence = influence * influence;
                        
                        // Color más claro (aumentar brillo)
                        const brightnessFactor = 1 + smoothInfluence * 0.8;
                        const brightColor = particle.originalColor.clone().multiplyScalar(brightnessFactor);
                        material.color.lerp(brightColor, 0.2);
                        
                        // Emissive más intenso
                        const brightEmissive = particle.originalEmissive.clone().multiplyScalar(1 + smoothInfluence * 0.8);
                        material.emissive.lerp(brightEmissive, 0.2);
                        material.emissiveIntensity = particle.originalEmissiveIntensity * (1 + smoothInfluence * 0.8);
                    } else {
                        // Volver al color original suavemente
                        material.color.lerp(particle.originalColor, 0.1);
                        material.emissive.lerp(particle.originalEmissive, 0.1);
                        material.emissiveIntensity += (particle.originalEmissiveIntensity - material.emissiveIntensity) * 0.1;
                    }
                }
            });
        });
    }

    // ============================================
    // RESPONSIVE
    // ============================================
    window.addEventListener('resize', () => {
        const width = window.innerWidth;
        const height = window.innerHeight;
        
        // Actualizar cámaras
        cameraBackground.aspect = width / height;
        cameraBackground.updateProjectionMatrix();
        cameraForeground.aspect = width / height;
        cameraForeground.updateProjectionMatrix();
        
        // Actualizar renderers
        rendererBackground.setSize(width, height);
        rendererForeground.setSize(width, height);
        composerBackground.setSize(width, height);
        
        // Refrescar ScrollTrigger después de resize
        ScrollTrigger.refresh();
    });
    
    // Refrescar ScrollTrigger cuando la página carga completamente
    // Esto asegura que las posiciones iniciales sean correctas y evita saltos al recargar
    window.addEventListener('load', () => {
        ScrollTrigger.refresh();
    });

    // Iniciar animación
    animate();
</script>