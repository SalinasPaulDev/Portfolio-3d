---
const jobs = [
    { company: 'Spaceguru', role: 'Frontend Developer', country: 'Argentina', city: 'Buenos Aires', lat: -34.6, lng: -58.4, countryName: 'Argentina' },
    { company: 'Company TBD', role: 'Frontend Developer', country: 'Chile', city: 'Santiago', lat: -33.4, lng: -70.7, countryName: 'Chile' },
    { company: 'Company TBD', role: 'Frontend Developer', country: 'Mexico', city: 'Mexico City', lat: 19.4, lng: -99.1, countryName: 'Mexico' },
    { company: 'Company TBD', role: 'Senior Frontend Developer', country: 'USA', city: 'San Francisco', lat: 37.8, lng: -122.4, countryName: 'United States of America' },
];
---

<section id="experience" class="h-dvh w-full relative flex flex-col md:flex-row items-center justify-center overflow-hidden px-8 md:px-32">
    <div class="absolute inset-0 md:relative md:w-1/2 md:h-full md:inset-auto md:shrink-0 pointer-events-none z-0">
        <canvas id="experience-canvas"></canvas>
    </div>

    <div class="relative z-10 md:w-1/2 flex flex-col gap-8 w-full max-w-2xl p-6 md:p-8 rounded-2xl bg-black/30 backdrop-blur-md">
        <h4 class="flex flex-col">Where <span class="text-yellow-500">I've worked</span></h4>
        <ul id="experience-list" class="flex flex-col gap-4">
            {jobs.map((job) => (
                <li
                    class="experience-item cursor-pointer group py-3 pl-5 border-l-2 border-white/10 hover:border-yellow-500 transition-colors"
                    data-lat={job.lat}
                    data-lng={job.lng}
                    data-country={job.countryName}
                >
                    <p class="text-xl md:text-2xl font-semibold text-white/90 group-hover:text-yellow-500 transition-colors">
                        {job.company}
                    </p>
                    <p class="text-sm md:text-base font-light text-white/60">
                        {job.role} — {job.country}, {job.city}
                    </p>
                </li>
            ))}
        </ul>
    </div>
</section>

<style>
    #experience-canvas {
        width: 100%;
        height: 100%;
        display: block;
    }
</style>

<script>
    // @ts-ignore
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
    import { gsap } from 'gsap';

    // Fixed target count — particles are distributed uniformly across the earth
    // surface (area-weighted), independent of the model's face count. Tune this
    // to balance density vs perf.
    const TARGET_PARTICLE_COUNT = 12000;

    const canvas = document.getElementById('experience-canvas') as HTMLCanvasElement | null;
    const section = document.getElementById('experience');
    const listItems = document.querySelectorAll<HTMLElement>('.experience-item');

    if (canvas && section) {
        const scene = new THREE.Scene();

        const getSize = () => {
            const rect = canvas.getBoundingClientRect();
            return {
                width: Math.max(1, rect.width),
                height: Math.max(1, rect.height),
            };
        };

        const initial = getSize();
        const camera = new THREE.PerspectiveCamera(45, initial.width / initial.height, 0.1, 100);
        camera.position.set(0, 0, 6);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        renderer.setSize(initial.width, initial.height, false);
        renderer.setClearColor(0x000000, 0);

        // Lights — MeshStandardMaterial needs them
        scene.add(new THREE.AmbientLight(0xffffff, 0.6));
        const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
        dirLight.position.set(5, 5, 5);
        scene.add(dirLight);
        const fillLight = new THREE.DirectionalLight(0xffffff, 0.5);
        fillLight.position.set(-5, -3, -5);
        scene.add(fillLight);

        const globeGroup = new THREE.Group();
        // XYZ: matrix = Rx * Ry, so Ry (longitude) is applied to the point first, then Rx (latitude).
        // This brings (lat, lng) to the front (+Z) correctly. YXZ swaps the order and sends
        // off-equator countries to the wrong spot, causing wild tween arcs between hovers.
        globeGroup.rotation.order = 'XYZ';
        scene.add(globeGroup);

        // ============================================
        // SURFACE SAMPLING (area-weighted, uniform density)
        // ============================================
        function sampleSurfaceUniform(
            object: THREE.Object3D,
            count: number
        ): THREE.Vector3[] {
            type Tri = {
                v1: THREE.Vector3;
                v2: THREE.Vector3;
                v3: THREE.Vector3;
                cumArea: number;
            };
            const tris: Tri[] = [];
            let totalArea = 0;
            const edge1 = new THREE.Vector3();
            const edge2 = new THREE.Vector3();
            const cross = new THREE.Vector3();

            const pushFace = (
                v1: THREE.Vector3,
                v2: THREE.Vector3,
                v3: THREE.Vector3
            ) => {
                edge1.subVectors(v2, v1);
                edge2.subVectors(v3, v1);
                cross.crossVectors(edge1, edge2);
                const area = 0.5 * cross.length();
                if (area <= 0) return;
                totalArea += area;
                tris.push({ v1, v2, v3, cumArea: totalArea });
            };

            object.traverse((child) => {
                const mesh = child as THREE.Mesh;
                if (!mesh.isMesh || !mesh.geometry) return;
                const positions = mesh.geometry.attributes.position;
                const index = mesh.geometry.index;
                if (!positions) return;
                const matrix = mesh.matrixWorld;

                const makeVert = (i: number) =>
                    new THREE.Vector3(
                        positions.getX(i),
                        positions.getY(i),
                        positions.getZ(i)
                    ).applyMatrix4(matrix);

                if (index) {
                    const arr = index.array;
                    for (let i = 0; i < arr.length; i += 3) {
                        pushFace(makeVert(arr[i]), makeVert(arr[i + 1]), makeVert(arr[i + 2]));
                    }
                } else {
                    for (let i = 0; i < positions.count; i += 3) {
                        pushFace(makeVert(i), makeVert(i + 1), makeVert(i + 2));
                    }
                }
            });

            const points: THREE.Vector3[] = [];
            if (tris.length === 0 || totalArea === 0) return points;

            for (let i = 0; i < count; i++) {
                const r = Math.random() * totalArea;
                // Binary search for the triangle whose cumulative area contains r
                let lo = 0;
                let hi = tris.length - 1;
                while (lo < hi) {
                    const mid = (lo + hi) >> 1;
                    if (tris[mid].cumArea < r) lo = mid + 1;
                    else hi = mid;
                }
                const t = tris[lo];
                let r1 = Math.random();
                let r2 = Math.random();
                if (r1 + r2 > 1) {
                    r1 = 1 - r1;
                    r2 = 1 - r2;
                }
                const r3 = 1 - r1 - r2;
                points.push(
                    new THREE.Vector3()
                        .addScaledVector(t.v1, r1)
                        .addScaledVector(t.v2, r2)
                        .addScaledVector(t.v3, r3)
                );
            }
            return points;
        }

        // ============================================
        // LAND / WATER CLASSIFIER (GeoJSON → point-in-polygon with bbox prefilter)
        // ============================================
        type LandRing = {
            ring: number[][]; // [lng, lat] pairs
            minLng: number;
            maxLng: number;
            minLat: number;
            maxLat: number;
        };
        const landRings: LandRing[] = [];

        async function loadLandData(): Promise<void> {
            try {
                const resp = await fetch('/data/land.json');
                if (!resp.ok) return;
                const geojson = await resp.json();
                for (const feature of geojson.features) {
                    const g = feature.geometry;
                    const polys: number[][][][] =
                        g.type === 'Polygon'
                            ? [g.coordinates]
                            : g.type === 'MultiPolygon'
                              ? g.coordinates
                              : [];
                    for (const polygon of polys) {
                        const outer = polygon[0];
                        if (!outer || outer.length === 0) continue;
                        let minLng = Infinity;
                        let maxLng = -Infinity;
                        let minLat = Infinity;
                        let maxLat = -Infinity;
                        for (const c of outer) {
                            if (c[0] < minLng) minLng = c[0];
                            if (c[0] > maxLng) maxLng = c[0];
                            if (c[1] < minLat) minLat = c[1];
                            if (c[1] > maxLat) maxLat = c[1];
                        }
                        landRings.push({ ring: outer, minLng, maxLng, minLat, maxLat });
                    }
                }
                console.log(`🗺️  Land classifier ready: ${landRings.length} rings`);
            } catch (err) {
                console.warn('Failed to load land data:', err);
            }
        }
        const landReady = loadLandData();

        function pointToLatLng(x: number, y: number, z: number): { lat: number; lng: number } {
            const len = Math.sqrt(x * x + y * y + z * z) || 1;
            const nx = x / len;
            const ny = y / len;
            const nz = z / len;
            const lat = (Math.asin(ny) * 180) / Math.PI;
            const lng = (Math.atan2(nx, nz) * 180) / Math.PI;
            return { lat, lng };
        }

        function isLandPoint(lat: number, lng: number): boolean {
            for (const r of landRings) {
                if (lng < r.minLng || lng > r.maxLng || lat < r.minLat || lat > r.maxLat) continue;
                const ring = r.ring;
                let inside = false;
                for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
                    const xi = ring[i][0];
                    const yi = ring[i][1];
                    const xj = ring[j][0];
                    const yj = ring[j][1];
                    if (
                        yi > lat !== yj > lat &&
                        lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi
                    ) {
                        inside = !inside;
                    }
                }
                if (inside) return true;
            }
            return false;
        }

        // ============================================
        // BUILD GLOBE AS A SINGLE INSTANCED MESH
        // ============================================
        function buildGlobeInstanced(
            earth: THREE.Object3D,
            template: THREE.Group,
            count: number
        ): THREE.InstancedMesh {
            // Extract the first mesh geometry from py-lod7.glb
            let sourceGeom: THREE.BufferGeometry | null = null;
            template.traverse((child) => {
                const m = child as THREE.Mesh;
                if (!sourceGeom && m.isMesh && m.geometry) {
                    sourceGeom = m.geometry.clone();
                }
            });
            const geom: THREE.BufferGeometry =
                sourceGeom ?? new THREE.TetrahedronGeometry(1);

            const points = sampleSurfaceUniform(earth, count);

            let minX = Infinity;
            let maxX = -Infinity;
            for (const p of points) {
                if (p.x < minX) minX = p.x;
                if (p.x > maxX) maxX = p.x;
            }
            const rangeX = maxX - minX || 1;

            const material = new THREE.MeshStandardMaterial({
                color: 0xffffff, // white so per-instance color shows directly
                metalness: 0.7,
                roughness: 0.3,
                emissive: 0x222222,
                emissiveIntensity: 0.9,
                transparent: true,
                opacity: 0.95,
            });

            const mesh = new THREE.InstancedMesh(geom, material, points.length);

            const colorStops = [
                new THREE.Color(0x4a0080),
                new THREE.Color(0x5a00b8),
                new THREE.Color(0x0066cc),
                new THREE.Color(0xcc3399),
                new THREE.Color(0xd96b00),
                new THREE.Color(0xff9900),
                new THREE.Color(0xffb700),
                new THREE.Color(0xffd740),
            ];

            const dummy = new THREE.Object3D();

            // Muted cold base tone for water particles
            const waterBase = new THREE.Color(0x1a2838);

            let landCount = 0;
            for (let i = 0; i < points.length; i++) {
                const p = points[i];

                const { lat, lng } = pointToLatLng(p.x, p.y, p.z);
                const isLand = isLandPoint(lat, lng);
                if (isLand) landCount++;

                // Land: bigger + bright gradient. Water: smaller + muted cool tone.
                const scale = isLand
                    ? 0.024 + Math.random() * 0.010 // land: 0.024–0.034
                    : 0.008 + Math.random() * 0.004; // water: 0.008–0.012

                dummy.position.set(p.x, p.y, p.z);
                dummy.rotation.set(
                    Math.random() * Math.PI * 2,
                    Math.random() * Math.PI * 2,
                    Math.random() * Math.PI * 2
                );
                dummy.scale.setScalar(scale);
                dummy.updateMatrix();
                mesh.setMatrixAt(i, dummy.matrix);

                let c: THREE.Color;
                if (isLand) {
                    // Bright rainbow gradient for continents
                    const nx = (p.x - minX) / rangeX;
                    if (nx < 0.14) c = colorStops[0].clone().lerp(colorStops[1], nx / 0.14);
                    else if (nx < 0.28) c = colorStops[1].clone().lerp(colorStops[2], (nx - 0.14) / 0.14);
                    else if (nx < 0.42) c = colorStops[2].clone().lerp(colorStops[3], (nx - 0.28) / 0.14);
                    else if (nx < 0.57) c = colorStops[3].clone().lerp(colorStops[4], (nx - 0.42) / 0.15);
                    else if (nx < 0.71) c = colorStops[4].clone().lerp(colorStops[5], (nx - 0.57) / 0.14);
                    else if (nx < 0.85) c = colorStops[5].clone().lerp(colorStops[6], (nx - 0.71) / 0.14);
                    else c = colorStops[6].clone().lerp(colorStops[7], (nx - 0.85) / 0.15);

                    const variation = (Math.random() - 0.5) * 0.08;
                    c.offsetHSL(0, 0, variation);
                    // Brighter floor so continents pop
                    const brightness = 0.95 + Math.random() * 0.25;
                    c.multiplyScalar(brightness);
                } else {
                    // Muted, desaturated, dark — "sad" water
                    c = waterBase.clone();
                    const variation = (Math.random() - 0.5) * 0.06;
                    c.offsetHSL(0, -0.1, variation);
                    const brightness = 0.35 + Math.random() * 0.25;
                    c.multiplyScalar(brightness);
                }

                mesh.setColorAt(i, c);
            }

            mesh.instanceMatrix.needsUpdate = true;
            if (mesh.instanceColor) mesh.instanceColor.needsUpdate = true;

            console.log(
                `🌊 Land/water split: ${landCount} land / ${points.length - landCount} water`
            );

            return mesh;
        }

        // ============================================
        // LOAD ASSETS
        // ============================================
        const loader = new GLTFLoader();

        loader.load('/triangles/py-lod7.glb', (triTpl) => {
            const triangleTemplate = triTpl.scene;

            loader.load('/earth-globe.glb', async (earthGltf) => {
                // Make sure the land classifier is ready before we build (so scales classify correctly)
                await landReady;

                const earth = earthGltf.scene;

                // Wrap so we can center + normalize scale without fighting the original transform
                const wrapper = new THREE.Group();
                wrapper.add(earth);
                wrapper.updateMatrixWorld(true);

                const bbox = new THREE.Box3().setFromObject(wrapper);
                const size = new THREE.Vector3();
                const center = new THREE.Vector3();
                bbox.getSize(size);
                bbox.getCenter(center);

                // Recenter earth so its bbox center is at local origin
                earth.position.sub(center);

                // Normalize so the largest dimension is ~2 units
                const maxDim = Math.max(size.x, size.y, size.z) || 1;
                wrapper.scale.setScalar(2 / maxDim);
                wrapper.updateMatrixWorld(true);

                const globeMesh = buildGlobeInstanced(
                    wrapper,
                    triangleTemplate,
                    TARGET_PARTICLE_COUNT
                );
                globeGroup.add(globeMesh);

                console.log(`🌍 Globe particle system: ${TARGET_PARTICLE_COUNT} instanced particles (1 draw call)`);

                // Default rotation — first job's country
                applyCountryRotation(jobs[0].lat, jobs[0].lng, false);
            });
        });

        // ============================================
        // COUNTRY OUTLINES (GeoJSON → sphere → LineLoop per ring)
        // ============================================
        type CountryEntry = {
            group: THREE.Group;
            material: THREE.LineBasicMaterial;
        };
        const countryEntries = new Map<string, CountryEntry>();
        // Slightly above the particle surface (globe is normalized to ~1 unit radius)
        const OUTLINE_RADIUS = 1.02;

        function latLngToSphere(lat: number, lng: number, radius: number): THREE.Vector3 {
            const latRad = (lat * Math.PI) / 180;
            const lngRad = (lng * Math.PI) / 180;
            return new THREE.Vector3(
                radius * Math.cos(latRad) * Math.sin(lngRad),
                radius * Math.sin(latRad),
                radius * Math.cos(latRad) * Math.cos(lngRad)
            );
        }

        async function loadCountryOutlines() {
            try {
                const resp = await fetch('/data/countries.json');
                if (!resp.ok) return;
                const geojson = await resp.json();

                for (const feature of geojson.features) {
                    const name: string = feature.properties.name;
                    const material = new THREE.LineBasicMaterial({
                        color: 0xeab308, // tailwind yellow-500
                        transparent: true,
                        opacity: 0,
                    });
                    const group = new THREE.Group();

                    const geometry = feature.geometry;
                    const polygons: number[][][][] =
                        geometry.type === 'Polygon'
                            ? [geometry.coordinates]
                            : geometry.type === 'MultiPolygon'
                              ? geometry.coordinates
                              : [];

                    for (const polygon of polygons) {
                        for (const ring of polygon) {
                            const positions: number[] = [];
                            for (const coord of ring) {
                                const lng = coord[0];
                                const lat = coord[1];
                                const p = latLngToSphere(lat, lng, OUTLINE_RADIUS);
                                positions.push(p.x, p.y, p.z);
                            }
                            const geom = new THREE.BufferGeometry();
                            geom.setAttribute(
                                'position',
                                new THREE.Float32BufferAttribute(positions, 3)
                            );
                            const line = new THREE.LineLoop(geom, material);
                            group.add(line);
                        }
                    }

                    group.visible = false;
                    globeGroup.add(group);
                    countryEntries.set(name, { group, material });
                }
                console.log(`🗺️  Country outlines loaded: ${countryEntries.size}`);
            } catch (err) {
                console.warn('Failed to load country outlines:', err);
            }
        }
        loadCountryOutlines();

        function showCountryOutline(name: string) {
            for (const [n, entry] of countryEntries) {
                if (n === name) {
                    entry.group.visible = true;
                    gsap.to(entry.material, {
                        opacity: 0.95,
                        duration: 0.4,
                        ease: 'power2.out',
                        overwrite: true,
                    });
                } else {
                    gsap.to(entry.material, {
                        opacity: 0,
                        duration: 0.25,
                        overwrite: true,
                        onComplete: () => {
                            entry.group.visible = false;
                        },
                    });
                }
            }
        }

        function hideAllCountryOutlines() {
            for (const entry of countryEntries.values()) {
                gsap.to(entry.material, {
                    opacity: 0,
                    duration: 0.3,
                    overwrite: true,
                    onComplete: () => {
                        entry.group.visible = false;
                    },
                });
            }
        }

        // ============================================
        // ROTATION TO COUNTRY
        // ============================================
        function applyCountryRotation(lat: number, lng: number, animated: boolean) {
            const targetY = -(lng * Math.PI) / 180;
            const targetX = (lat * Math.PI) / 180;

            if (animated) {
                gsap.to(globeGroup.rotation, {
                    x: targetX,
                    y: targetY,
                    duration: 1.2,
                    ease: 'power2.inOut',
                    overwrite: true,
                });
            } else {
                globeGroup.rotation.x = targetX;
                globeGroup.rotation.y = targetY;
            }
        }

        listItems.forEach((item) => {
            const lat = parseFloat(item.dataset.lat || '0');
            const lng = parseFloat(item.dataset.lng || '0');
            const countryName = item.dataset.country || '';
            item.addEventListener('mouseenter', () => {
                applyCountryRotation(lat, lng, true);
                showCountryOutline(countryName);
            });
        });

        // Hide highlights when the cursor leaves the list entirely.
        // Moving between items just swaps highlights (mouseenter fires on the next item).
        const listEl = document.getElementById('experience-list');
        listEl?.addEventListener('mouseleave', () => {
            hideAllCountryOutlines();
        });

        // ============================================
        // RENDER LOOP (gated by IntersectionObserver for perf)
        // ============================================
        let isVisible = false;
        const observer = new IntersectionObserver(
            (entries) => {
                isVisible = entries[0].isIntersecting;
            },
            { threshold: 0.05 }
        );
        observer.observe(section);

        function animate() {
            requestAnimationFrame(animate);
            if (isVisible) {
                renderer.render(scene, camera);
            }
        }
        animate();

        // ============================================
        // RESIZE
        // ============================================
        const onResize = () => {
            const { width, height } = getSize();
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height, false);
        };
        window.addEventListener('resize', onResize);
        const ro = new ResizeObserver(onResize);
        ro.observe(canvas);
    }
</script>
