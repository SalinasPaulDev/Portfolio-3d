<section id="experience" class="h-dvh w-full relative flex flex-col md:flex-row items-center justify-center overflow-hidden px-8 md:px-32">
    <div id="experience-canvas-wrap" class="absolute inset-0 pointer-events-none z-0">
        <canvas id="experience-canvas"></canvas>
    </div>

    <div id="experience-text-card" class="relative z-10 md:w-1/2 md:ml-auto w-full max-w-2xl p-6 md:p-8 rounded-2xl bg-black/30 backdrop-blur-md">
        <div class="experience-stack">
            {/* =================== LIST VIEW =================== */}
            <div id="experience-list-view" class="experience-stack-cell flex flex-col gap-6">
                <div class="flex flex-col gap-2">
                    <h4 class="flex flex-col">Where <span class="text-yellow-500">I've worked</span></h4>
                    <p id="experience-hint" class="text-[0.7rem] uppercase tracking-[0.25em] text-yellow-500/80 flex items-center gap-2">
                        <span>Click a role to explore</span>
                        <span id="experience-hint-arrow" class="inline-block">→</span>
                    </p>
                </div>
                <ul id="experience-list" class="flex flex-col gap-3">
                    {jobs.map((job, index) => (
                        <li
                            class="experience-item cursor-pointer group relative py-3 pl-5 border-l-2 border-white/10 transition-all duration-300"
                            data-index={index}
                            data-lat={job.lat}
                            data-lng={job.lng}
                            data-country={job.countryName}
                        >
                            <div class="flex items-baseline justify-between gap-3">
                                <p class="job-company text-lg md:text-2xl font-semibold text-white/90 transition-colors">
                                    {job.company}
                                </p>
                                <span class="job-period-inline text-[0.6rem] md:text-[0.65rem] uppercase tracking-[0.2em] text-white/40 whitespace-nowrap">
                                    {job.period}
                                </span>
                            </div>
                            <p class="job-role-line text-xs md:text-base font-light text-white/60">
                                {job.role} — {job.country}, {job.city}
                            </p>
                        </li>
                    ))}
                </ul>
            </div>

            {/* =================== DETAIL VIEW =================== */}
            <div id="experience-detail-view" class="experience-stack-cell pointer-events-none">
                {jobs.map((job, index) => (
                    <div class="detail-panel flex flex-col gap-3 md:gap-4" data-index={index}>
                        <button
                            type="button"
                            class="detail-back self-start inline-flex items-center gap-2 text-[0.7rem] uppercase tracking-[0.25em] text-yellow-500/80 hover:text-yellow-500 transition-colors cursor-pointer"
                        >
                            <span class="detail-back-arrow text-sm leading-none">←</span>
                            <span>Back to list</span>
                        </button>

                        <div class="flex flex-col gap-1">
                            <span class="detail-period text-[0.65rem] md:text-[0.7rem] uppercase tracking-[0.25em] text-yellow-500/70">
                                {job.period}
                            </span>
                            <p class="detail-company text-xl md:text-3xl font-semibold text-yellow-500 leading-tight">
                                {job.company}
                            </p>
                            <p class="detail-role text-xs md:text-base font-light text-white/60">
                                {job.role} — {job.country}, {job.city}
                            </p>
                        </div>

                        <p class="detail-summary text-xs md:text-base text-white/80 leading-relaxed">
                            {job.summary}
                        </p>

                        <div class="detail-stack flex flex-wrap gap-1.5">
                            {job.stack.map((tech) => (
                                <span class="stack-chip text-[0.7rem] px-2.5 py-1 rounded-full border border-yellow-500/30 bg-yellow-500/5 text-white/85">
                                    {tech}
                                </span>
                            ))}
                        </div>

                        <div class="detail-highlights flex flex-col gap-1.5 md:gap-2">
                            {job.highlights.map((h) => (
                                <div class="highlight-item relative pl-3 md:pl-4 pr-2.5 md:pr-3 py-1.5 md:py-2 rounded-md bg-white/[0.03] border-l-2 border-yellow-500/60">
                                    <p class="text-[0.7rem] md:text-sm text-white/80 leading-snug">{h}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    #experience-canvas {
        width: 100%;
        height: 100%;
        display: block;
    }

    /* Grid-stack: both views live in the same cell so the card auto-sizes
       to the tallest view. No absolute positioning, no overflow clipping,
       no fixed min-heights. */
    .experience-stack {
        display: grid;
        grid-template-columns: 1fr;
    }

    .experience-stack-cell {
        grid-column: 1;
        grid-row: 1;
    }

    /* Inside the detail view, the 4 panels also grid-stack so the card
       sizes to the tallest panel. Prevents jumps between panels of
       different heights. Scoped to the ID to avoid colliding with the
       .detail-stack class used on the chip container. */
    #experience-detail-view {
        display: grid;
        grid-template-columns: 1fr;
    }

    #experience-detail-view > .detail-panel {
        grid-column: 1;
        grid-row: 1;
    }

    .experience-item:hover {
        border-left-color: rgba(234, 179, 8, 0.6);
    }

    .experience-item:hover .job-company {
        color: rgba(234, 179, 8, 0.9);
    }

    .experience-item:hover .job-period-inline {
        color: rgba(234, 179, 8, 0.6);
    }

    .detail-back:hover .detail-back-arrow {
        transform: translateX(-3px);
    }

    .detail-back-arrow {
        transition: transform 0.25s ease;
    }
</style>

<script>
    // @ts-ignore
    import * as THREE from 'three';
    import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Fixed target count — particles are distributed uniformly across the earth
    // surface (area-weighted), independent of the model's face count. Tune this
    // to balance density vs perf.
    const TARGET_PARTICLE_COUNT = 13000;

    const canvas = document.getElementById('experience-canvas') as HTMLCanvasElement | null;
    const section = document.getElementById('experience');
    const listItems = document.querySelectorAll<HTMLElement>('.experience-item');

    if (canvas && section) {
        const scene = new THREE.Scene();

        const getSize = () => {
            const rect = canvas.getBoundingClientRect();
            return {
                width: Math.max(1, rect.width),
                height: Math.max(1, rect.height),
            };
        };

        const initial = getSize();
        const camera = new THREE.PerspectiveCamera(45, initial.width / initial.height, 0.1, 100);
        camera.position.set(0, 0, 9);
        camera.lookAt(0, 0, 0);

        const renderer = new THREE.WebGLRenderer({
            canvas,
            antialias: true,
            alpha: true,
            powerPreference: 'high-performance',
        });
        // DPR capped at 1.5 — full-bleed canvas makes DPR 2 very expensive,
        // and the background Canvas.astro is sharing the GPU/main-thread budget.
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
        renderer.setSize(initial.width, initial.height, false);
        renderer.setClearColor(0x000000, 0);

        // Lights — MeshStandardMaterial needs them
        scene.add(new THREE.AmbientLight(0xffffff, 0.6));
        const dirLight = new THREE.DirectionalLight(0xffffff, 1.2);
        dirLight.position.set(5, 5, 5);
        scene.add(dirLight);
        const fillLight = new THREE.DirectionalLight(0xffffff, 0.5);
        fillLight.position.set(-5, -3, -5);
        scene.add(fillLight);
        // Golden accent light — toned down for InstancedMesh (per-instance colors wash out under very high intensity)
        const spotLightFg = new THREE.DirectionalLight(0xffd700, 2.5);
        spotLightFg.position.set(2, 2, 8);
        scene.add(spotLightFg);

        const globeGroup = new THREE.Group();
        // XYZ: matrix = Rx * Ry, so Ry (longitude) is applied to the point first, then Rx (latitude).
        // This brings (lat, lng) to the front (+Z) correctly. YXZ swaps the order and sends
        // off-equator countries to the wrong spot, causing wild tween arcs between hovers.
        globeGroup.rotation.order = 'XYZ';
        globeGroup.scale.setScalar(2.5);
        scene.add(globeGroup);

        // ============================================
        // INTRO ANIMATION STATE
        // Pre-hides the canvas + text card so the scroll-triggered
        // timeline can fade the section in with a spin + slide.
        // Final state after the intro matches the original working
        // resting state (position.x = -0.8, first-job rotation).
        // ============================================
        const canvasWrap = document.getElementById('experience-canvas-wrap');
        const textCard = document.getElementById('experience-text-card');
        const experienceHint = document.getElementById('experience-hint');
        const experienceHintArrow = document.getElementById('experience-hint-arrow');
        const listView = document.getElementById('experience-list-view');
        const detailView = document.getElementById('experience-detail-view');
        const detailPanels = document.querySelectorAll<HTMLElement>('.detail-panel');
        const backButtons = document.querySelectorAll<HTMLElement>('.detail-back');

        if (canvasWrap) gsap.set(canvasWrap, { autoAlpha: 0 });
        if (textCard) gsap.set(textCard, { autoAlpha: 0, y: 20 });
        if (experienceHint) gsap.set(experienceHint, { autoAlpha: 0 });
        gsap.set('.experience-item', { autoAlpha: 0, y: 15 });
        // Detail view starts hidden; panels stack inside it (all absolute/inset-0).
        if (detailView) gsap.set(detailView, { autoAlpha: 0, pointerEvents: 'none' });
        gsap.set(detailPanels, { autoAlpha: 0 });
        // Globe 3D object starts below camera view + smaller for the fade-up entrance
        globeGroup.position.y = -4;
        globeGroup.scale.setScalar(1.0);

        let globeLoaded = false;
        let scrollEntered = false;
        let introStarted = false;

        // Project a viewport x (as fraction of window width) onto a world-X
        // on the globe plane (z=0). Used for both the intro start (center)
        // and the resting position (left quarter on desktop, center on mobile).
        const worldXForScreenFraction = (frac: number) => {
            const rect = canvas.getBoundingClientRect();
            if (rect.width === 0) return 0;
            const screenPx = window.innerWidth * frac;
            const pxFromCanvasCenter = screenPx - (rect.left + rect.width / 2);
            const ndcX = pxFromCanvasCenter / (rect.width / 2);
            const vFov = (camera.fov * Math.PI) / 180;
            const halfH = Math.tan(vFov / 2) * camera.position.z;
            const halfW = halfH * camera.aspect;
            return ndcX * halfW;
        };

        const isDesktop = () => window.matchMedia('(min-width: 768px)').matches;
        const computeIntroStartWorldX = () => worldXForScreenFraction(0.5);
        const computeRestingWorldX = () =>
            worldXForScreenFraction(isDesktop() ? 0.33 : 0.5);

        // Start the globe centered — the intro timeline will slide it left.
        globeGroup.position.x = computeIntroStartWorldX();

        const tryStartIntro = () => {
            if (!globeLoaded || !scrollEntered || introStarted) return;
            introStarted = true;

            const firstItem = listItems[0];
            if (!firstItem) return;
            const lat = parseFloat(firstItem.dataset.lat || '0');
            const lng = parseFloat(firstItem.dataset.lng || '0');
            const finalRotY = -(lng * Math.PI) / 180;
            const finalRotX = (lat * Math.PI) / 180;

            const tl = gsap.timeline();

            // 1. Quick canvas reveal
            if (canvasWrap) {
                tl.to(canvasWrap, { autoAlpha: 1, duration: 0.3, ease: 'power2.out' });
            }

            // 2. Fade-up: the 3D globe rises from below + scales up
            tl.to(globeGroup.position, { y: 0, duration: 1.0, ease: 'power3.out' }, '-=0.1');
            tl.to(globeGroup.scale, { x: 2.5, y: 2.5, z: 2.5, duration: 1.0, ease: 'power3.out' }, '<');

            // 3. Spin: full 360° + tilt to first country (starts before rise finishes)
            tl.to(
                globeGroup.rotation,
                {
                    x: finalRotX,
                    y: finalRotY + Math.PI * 2,
                    duration: 1.5,
                    ease: 'power3.inOut',
                    onComplete: () => {
                        globeGroup.rotation.y = finalRotY;
                    },
                },
                '-=0.3'
            );

            // 4. Slide from center to left
            tl.to(
                globeGroup.position,
                {
                    x: computeRestingWorldX(),
                    duration: 1.0,
                    ease: 'power3.inOut',
                },
                '-=0.3'
            );

            // 5. Text card + list items
            if (textCard) {
                tl.to(
                    textCard,
                    {
                        autoAlpha: 1,
                        y: 0,
                        duration: 0.6,
                        ease: 'power2.out',
                    },
                    '-=0.6'
                );
            }
            tl.to(
                '.experience-item',
                {
                    autoAlpha: 1,
                    y: 0,
                    duration: 0.4,
                    stagger: 0.1,
                    ease: 'power2.out',
                },
                '-=0.3'
            );

            // Hint reveals last, then starts its gentle arrow pulse
            if (experienceHint) {
                tl.to(
                    experienceHint,
                    { autoAlpha: 1, duration: 0.4, ease: 'power2.out' },
                    '-=0.1'
                );
            }
            if (experienceHintArrow) {
                gsap.to(experienceHintArrow, {
                    x: 5,
                    duration: 0.9,
                    repeat: -1,
                    yoyo: true,
                    ease: 'power1.inOut',
                });
            }
        };

        ScrollTrigger.create({
            trigger: section,
            start: 'top 70%',
            once: true,
            onEnter: () => {
                scrollEntered = true;
                tryStartIntro();
            },
        });

        // Per-instance animation data (populated by buildGlobeInstanced).
        // Mirrors the dev.glb triangle particles: continuous rotation,
        // radial float, and a hover scale that lerps currentScale → targetScale.
        type GlobeInstance = {
            basePos: THREE.Vector3;
            baseScale: number;
            currentScale: number;
            targetScale: number;
            rotX: number;
            rotY: number;
            rotZ: number;
            rotSpeedX: number;
            rotSpeedY: number;
            rotSpeedZ: number;
            floatOffset: number;
            baseColor: THREE.Color;
            currentBrightness: number;
            targetBrightness: number;
            // Country the particle belongs to, or null if water / uncovered land.
            // Drives the spotlight hover effect.
            countryName: string | null;
        };
        const globeInstances: GlobeInstance[] = [];
        let globeMesh: THREE.InstancedMesh | null = null;

        // ============================================
        // SURFACE SAMPLING (area-weighted, uniform density)
        // ============================================
        function sampleSurfaceUniform(
            object: THREE.Object3D,
            count: number
        ): THREE.Vector3[] {
            type Tri = {
                v1: THREE.Vector3;
                v2: THREE.Vector3;
                v3: THREE.Vector3;
                cumArea: number;
            };
            const tris: Tri[] = [];
            let totalArea = 0;
            const edge1 = new THREE.Vector3();
            const edge2 = new THREE.Vector3();
            const cross = new THREE.Vector3();

            const pushFace = (
                v1: THREE.Vector3,
                v2: THREE.Vector3,
                v3: THREE.Vector3
            ) => {
                edge1.subVectors(v2, v1);
                edge2.subVectors(v3, v1);
                cross.crossVectors(edge1, edge2);
                const area = 0.5 * cross.length();
                if (area <= 0) return;
                totalArea += area;
                tris.push({ v1, v2, v3, cumArea: totalArea });
            };

            object.traverse((child) => {
                const mesh = child as THREE.Mesh;
                if (!mesh.isMesh || !mesh.geometry) return;
                const positions = mesh.geometry.attributes.position;
                const index = mesh.geometry.index;
                if (!positions) return;
                const matrix = mesh.matrixWorld;

                const makeVert = (i: number) =>
                    new THREE.Vector3(
                        positions.getX(i),
                        positions.getY(i),
                        positions.getZ(i)
                    ).applyMatrix4(matrix);

                if (index) {
                    const arr = index.array;
                    for (let i = 0; i < arr.length; i += 3) {
                        pushFace(makeVert(arr[i]), makeVert(arr[i + 1]), makeVert(arr[i + 2]));
                    }
                } else {
                    for (let i = 0; i < positions.count; i += 3) {
                        pushFace(makeVert(i), makeVert(i + 1), makeVert(i + 2));
                    }
                }
            });

            const points: THREE.Vector3[] = [];
            if (tris.length === 0 || totalArea === 0) return points;

            for (let i = 0; i < count; i++) {
                const r = Math.random() * totalArea;
                // Binary search for the triangle whose cumulative area contains r
                let lo = 0;
                let hi = tris.length - 1;
                while (lo < hi) {
                    const mid = (lo + hi) >> 1;
                    if (tris[mid].cumArea < r) lo = mid + 1;
                    else hi = mid;
                }
                const t = tris[lo];
                let r1 = Math.random();
                let r2 = Math.random();
                if (r1 + r2 > 1) {
                    r1 = 1 - r1;
                    r2 = 1 - r2;
                }
                const r3 = 1 - r1 - r2;
                points.push(
                    new THREE.Vector3()
                        .addScaledVector(t.v1, r1)
                        .addScaledVector(t.v2, r2)
                        .addScaledVector(t.v3, r3)
                );
            }
            return points;
        }

        // ============================================
        // LAND / WATER CLASSIFIER (GeoJSON → point-in-polygon with bbox prefilter)
        // ============================================
        type LandRing = {
            ring: number[][]; // [lng, lat] pairs
            minLng: number;
            maxLng: number;
            minLat: number;
            maxLat: number;
        };
        const landRings: LandRing[] = [];

        async function loadLandData(): Promise<void> {
            try {
                const resp = await fetch('/data/land.json');
                if (!resp.ok) return;
                const geojson = await resp.json();
                for (const feature of geojson.features) {
                    const g = feature.geometry;
                    const polys: number[][][][] =
                        g.type === 'Polygon'
                            ? [g.coordinates]
                            : g.type === 'MultiPolygon'
                              ? g.coordinates
                              : [];
                    for (const polygon of polys) {
                        const outer = polygon[0];
                        if (!outer || outer.length === 0) continue;
                        let minLng = Infinity;
                        let maxLng = -Infinity;
                        let minLat = Infinity;
                        let maxLat = -Infinity;
                        for (const c of outer) {
                            if (c[0] < minLng) minLng = c[0];
                            if (c[0] > maxLng) maxLng = c[0];
                            if (c[1] < minLat) minLat = c[1];
                            if (c[1] > maxLat) maxLat = c[1];
                        }
                        landRings.push({ ring: outer, minLng, maxLng, minLat, maxLat });
                    }
                }
                console.log(`🗺️  Land classifier ready: ${landRings.length} rings`);
            } catch (err) {
                console.warn('Failed to load land data:', err);
            }
        }
        const landReady = loadLandData();

        function pointToLatLng(x: number, y: number, z: number): { lat: number; lng: number } {
            const len = Math.sqrt(x * x + y * y + z * z) || 1;
            const nx = x / len;
            const ny = y / len;
            const nz = z / len;
            const lat = (Math.asin(ny) * 180) / Math.PI;
            const lng = (Math.atan2(nx, nz) * 180) / Math.PI;
            return { lat, lng };
        }

        // Country classifier — same point-in-polygon approach as isLandPoint, but
        // keyed by country name so each particle can know which country it sits in.
        type CountryRing = {
            name: string;
            ring: number[][];
            minLng: number;
            maxLng: number;
            minLat: number;
            maxLat: number;
        };
        const countryRings: CountryRing[] = [];

        async function loadCountryClassifier(): Promise<void> {
            try {
                const resp = await fetch('/data/countries.json');
                if (!resp.ok) return;
                const geojson = await resp.json();
                for (const feature of geojson.features) {
                    const name: string = feature.properties.name;
                    const g = feature.geometry;
                    const polys: number[][][][] =
                        g.type === 'Polygon'
                            ? [g.coordinates]
                            : g.type === 'MultiPolygon'
                              ? g.coordinates
                              : [];
                    for (const polygon of polys) {
                        const outer = polygon[0];
                        if (!outer || outer.length === 0) continue;
                        let minLng = Infinity;
                        let maxLng = -Infinity;
                        let minLat = Infinity;
                        let maxLat = -Infinity;
                        for (const c of outer) {
                            if (c[0] < minLng) minLng = c[0];
                            if (c[0] > maxLng) maxLng = c[0];
                            if (c[1] < minLat) minLat = c[1];
                            if (c[1] > maxLat) maxLat = c[1];
                        }
                        countryRings.push({ name, ring: outer, minLng, maxLng, minLat, maxLat });
                    }
                }
                console.log(`🏳️  Country classifier ready: ${countryRings.length} rings`);
            } catch (err) {
                console.warn('Failed to load country classifier:', err);
            }
        }
        const countryClassifierReady = loadCountryClassifier();

        function pointToCountry(lat: number, lng: number): string | null {
            for (const r of countryRings) {
                if (lng < r.minLng || lng > r.maxLng || lat < r.minLat || lat > r.maxLat) continue;
                const ring = r.ring;
                let inside = false;
                for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
                    const xi = ring[i][0];
                    const yi = ring[i][1];
                    const xj = ring[j][0];
                    const yj = ring[j][1];
                    if (
                        yi > lat !== yj > lat &&
                        lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi
                    ) {
                        inside = !inside;
                    }
                }
                if (inside) return r.name;
            }
            return null;
        }

        function isLandPoint(lat: number, lng: number): boolean {
            for (const r of landRings) {
                if (lng < r.minLng || lng > r.maxLng || lat < r.minLat || lat > r.maxLat) continue;
                const ring = r.ring;
                let inside = false;
                for (let i = 0, j = ring.length - 1; i < ring.length; j = i++) {
                    const xi = ring[i][0];
                    const yi = ring[i][1];
                    const xj = ring[j][0];
                    const yj = ring[j][1];
                    if (
                        yi > lat !== yj > lat &&
                        lng < ((xj - xi) * (lat - yi)) / (yj - yi) + xi
                    ) {
                        inside = !inside;
                    }
                }
                if (inside) return true;
            }
            return false;
        }

        // ============================================
        // BUILD GLOBE AS A SINGLE INSTANCED MESH
        // ============================================
        async function buildGlobeInstanced(
            earth: THREE.Object3D,
            template: THREE.Group,
            count: number
        ): Promise<THREE.InstancedMesh> {
            // Extract the first mesh geometry from py-lod7.glb
            let sourceGeom: THREE.BufferGeometry | null = null;
            template.traverse((child) => {
                const m = child as THREE.Mesh;
                if (!sourceGeom && m.isMesh && m.geometry) {
                    sourceGeom = m.geometry.clone();
                }
            });
            const geom: THREE.BufferGeometry =
                sourceGeom ?? new THREE.TetrahedronGeometry(1);

            // Deterministic Fibonacci sphere distribution: guarantees uniform per-area
            // density with no Monte Carlo variance, so small countries like Argentina
            // get their fair share of particles. We oversample heavily, keep every
            // land point, and thin the water.
            //
            // The earth mesh (`earth`) is unused for sampling now — it was only here to
            // provide the sphere radius, which the wrapper normalization already made 1.
            const OVER_SAMPLE = 4;
            const WATER_KEEP_PROB = 0.15;
            const totalSamples = Math.floor(count * OVER_SAMPLE);
            const goldenRatio = (1 + Math.sqrt(5)) / 2;
            const points: THREE.Vector3[] = [];
            const pointIsLand: boolean[] = [];
            const pointCountry: (string | null)[] = [];
            for (let k = 0; k < totalSamples; k++) {
                if (k > 0 && k % 5000 === 0) {
                    await new Promise<void>(r => setTimeout(r, 0));
                }
                const y = 1 - (2 * (k + 0.5)) / totalSamples; // [-1, 1]
                const r = Math.sqrt(1 - y * y);
                const theta = (2 * Math.PI * k) / goldenRatio;
                const x = Math.cos(theta) * r;
                const z = Math.sin(theta) * r;
                const p = new THREE.Vector3(x, y, z);

                const { lat, lng } = pointToLatLng(x, y, z);
                const isLand = isLandPoint(lat, lng);
                if (isLand) {
                    points.push(p);
                    pointIsLand.push(true);
                    pointCountry.push(pointToCountry(lat, lng));
                } else if (Math.random() < WATER_KEEP_PROB) {
                    points.push(p);
                    pointIsLand.push(false);
                    pointCountry.push(null);
                }
            }

            let minX = Infinity;
            let maxX = -Infinity;
            for (const p of points) {
                if (p.x < minX) minX = p.x;
                if (p.x > maxX) maxX = p.x;
            }
            const rangeX = maxX - minX || 1;

            const material = new THREE.MeshStandardMaterial({
                color: 0xffffff, // white so per-instance color shows directly
                metalness: 0.3,
                roughness: 0.4,
                emissive: 0x444444,
                emissiveIntensity: 0.5,
                transparent: true,
                opacity: 0.95,
            });

            const mesh = new THREE.InstancedMesh(geom, material, points.length);

            const colorStops = [
                new THREE.Color(0x4a0080),
                new THREE.Color(0x5a00b8),
                new THREE.Color(0x0066cc),
                new THREE.Color(0xcc3399),
                new THREE.Color(0xd96b00),
                new THREE.Color(0xff9900),
                new THREE.Color(0xffb700),
                new THREE.Color(0xffd740),
            ];

            const dummy = new THREE.Object3D();

            // Muted cold base tone for water particles
            const waterBase = new THREE.Color(0x1a2838);

            let landCount = 0;
            for (let i = 0; i < points.length; i++) {
                if (i > 0 && i % 5000 === 0) {
                    await new Promise<void>(r => setTimeout(r, 0));
                }
                const p = points[i];
                const isLand = pointIsLand[i];
                if (isLand) landCount++;

                // Small triangles so dense land sampling fills continents without
                // visible overlap/clumping. Mix of two ranges for subtle texture variation.
                let scale: number;
                if (isLand) {
                    const r = Math.random();
                    if (r < 0.6) scale = 0.007 + Math.random() * 0.005; // fine fillers: 0.007–0.012
                    else scale = 0.012 + Math.random() * 0.006;        // slightly larger: 0.012–0.018
                } else {
                    scale = 0.005 + Math.random() * 0.003;             // water: 0.005–0.008
                }

                const initRotX = Math.random() * Math.PI * 2;
                const initRotY = Math.random() * Math.PI * 2;
                const initRotZ = Math.random() * Math.PI * 2;

                // Push each particle outward along its normal by ~its own extent so
                // the triangle's rotation never dips vertices below the sphere surface.
                const radius = Math.sqrt(p.x * p.x + p.y * p.y + p.z * p.z) || 1;
                const outwardFactor = 1 + scale * 1.2 / radius;
                const px = p.x * outwardFactor;
                const py = p.y * outwardFactor;
                const pz = p.z * outwardFactor;

                dummy.position.set(px, py, pz);
                dummy.rotation.set(initRotX, initRotY, initRotZ);
                dummy.scale.setScalar(scale);
                dummy.updateMatrix();
                mesh.setMatrixAt(i, dummy.matrix);

                globeInstances.push({
                    basePos: new THREE.Vector3(px, py, pz),
                    baseScale: scale,
                    currentScale: scale,
                    targetScale: scale,
                    rotX: initRotX,
                    rotY: initRotY,
                    rotZ: initRotZ,
                    rotSpeedX: 0.005 + Math.random() * 0.008,
                    rotSpeedY: 0.005 + Math.random() * 0.008,
                    rotSpeedZ: 0.005 + Math.random() * 0.008,
                    floatOffset: Math.random() * Math.PI * 2,
                    baseColor: new THREE.Color(1, 1, 1), // filled after color block below
                    currentBrightness: 1.0,
                    targetBrightness: 1.0,
                    countryName: pointCountry[i],
                });

                let c: THREE.Color;
                if (isLand) {
                    // Flipped gradient: Americas (low X) get warm/bright colors,
                    // Europe/Africa/Asia (high X) get cool purples.
                    const nx = 1 - (p.x - minX) / rangeX;
                    if (nx < 0.14) c = colorStops[0].clone().lerp(colorStops[1], nx / 0.14);
                    else if (nx < 0.28) c = colorStops[1].clone().lerp(colorStops[2], (nx - 0.14) / 0.14);
                    else if (nx < 0.42) c = colorStops[2].clone().lerp(colorStops[3], (nx - 0.28) / 0.14);
                    else if (nx < 0.57) c = colorStops[3].clone().lerp(colorStops[4], (nx - 0.42) / 0.15);
                    else if (nx < 0.71) c = colorStops[4].clone().lerp(colorStops[5], (nx - 0.57) / 0.14);
                    else if (nx < 0.85) c = colorStops[5].clone().lerp(colorStops[6], (nx - 0.71) / 0.14);
                    else c = colorStops[6].clone().lerp(colorStops[7], (nx - 0.85) / 0.15);

                    const variation = (Math.random() - 0.5) * 0.08;
                    c.offsetHSL(0, 0, variation);
                    // Same brightness curve as dev.glb particles in Canvas.astro
                    const brightness = 0.6 + nx * 0.35;
                    c.multiplyScalar(brightness);
                } else {
                    // Muted, desaturated, dark — "sad" water
                    c = waterBase.clone();
                    const variation = (Math.random() - 0.5) * 0.06;
                    c.offsetHSL(0, -0.1, variation);
                    const brightness = 0.35 + Math.random() * 0.25;
                    c.multiplyScalar(brightness);
                }

                mesh.setColorAt(i, c);
                globeInstances[i].baseColor.copy(c);
            }

            mesh.instanceMatrix.needsUpdate = true;
            if (mesh.instanceColor) mesh.instanceColor.needsUpdate = true;

            console.log(
                `🌊 Land/water split: ${landCount} land / ${points.length - landCount} water`
            );

            return mesh;
        }

        // ============================================
        // LOAD ASSETS
        // ============================================
        const loader = new GLTFLoader();

        loader.load('/triangles/py-lod7.glb', (triTpl) => {
            const triangleTemplate = triTpl.scene;

            loader.load('/earth-globe.glb', async (earthGltf) => {
                // Make sure the land + country classifiers are ready before we build
                await landReady;
                await countryClassifierReady;

                const earth = earthGltf.scene;

                // Wrap so we can center + normalize scale without fighting the original transform
                const wrapper = new THREE.Group();
                wrapper.add(earth);
                wrapper.updateMatrixWorld(true);

                const bbox = new THREE.Box3().setFromObject(wrapper);
                const size = new THREE.Vector3();
                const center = new THREE.Vector3();
                bbox.getSize(size);
                bbox.getCenter(center);

                // Recenter earth so its bbox center is at local origin
                earth.position.sub(center);

                // Normalize so the largest dimension is ~2 units
                const maxDim = Math.max(size.x, size.y, size.z) || 1;
                wrapper.scale.setScalar(2 / maxDim);
                wrapper.updateMatrixWorld(true);

                globeMesh = await buildGlobeInstanced(
                    wrapper,
                    triangleTemplate,
                    TARGET_PARTICLE_COUNT
                );
                globeGroup.add(globeMesh);

                console.log(`🌍 Globe particle system: ${TARGET_PARTICLE_COUNT} instanced particles (1 draw call)`);

                // Default rotation — first job's country.
                // Deferred into the intro timeline (see tryStartIntro) so the
                // reveal spin lands exactly on the first-job orientation.
                globeLoaded = true;
                tryStartIntro();
            });
        });

        // ============================================
   
        // COUNTRY HOVER STATE
        // The animate loop uses this to dim non-hovered particles and
        // boost + pulse particles whose countryName matches.
        // ============================================
        let hoveredCountry: string | null = null;

        // ============================================
        // ROTATION TO COUNTRY
        // ============================================
        function applyCountryRotation(lat: number, lng: number, animated: boolean) {
            const targetY = -(lng * Math.PI) / 180;
            const targetX = (lat * Math.PI) / 180;

            if (animated) {
                gsap.to(globeGroup.rotation, {
                    x: targetX,
                    y: targetY,
                    duration: 1.2,
                    ease: 'power2.inOut',
                    overwrite: true,
                });
            } else {
                globeGroup.rotation.x = targetX;
                globeGroup.rotation.y = targetY;
            }
        }

        // ============================================
        // VIEW SWAP: LIST <-> DETAIL
        // Clicking a job fades out the list view and fades the corresponding
        // detail panel in (both stacked absolute inside the same card).
        // The detail panel animates its own internal content in a stagger.
        // Back button reverses the transition.
        // ============================================
        let activeIndex: number | null = null;
        let hintDismissed = false;
        let isAnimating = false;

        const animateDetailIn = (panel: HTMLElement) => {
            const backBtn = panel.querySelector('.detail-back');
            const period = panel.querySelector('.detail-period');
            const company = panel.querySelector('.detail-company');
            const role = panel.querySelector('.detail-role');
            const summary = panel.querySelector('.detail-summary');
            const chips = panel.querySelectorAll('.stack-chip');
            const highlights = panel.querySelectorAll('.highlight-item');

            const sequence: (Element | null)[] = [backBtn, period, company, role, summary];
            sequence.forEach((el, idx) => {
                if (!el) return;
                gsap.fromTo(
                    el,
                    { autoAlpha: 0, y: 10 },
                    {
                        autoAlpha: 1,
                        y: 0,
                        duration: 0.4,
                        delay: 0.05 + idx * 0.06,
                        ease: 'power2.out',
                    }
                );
            });
            if (chips.length) {
                gsap.fromTo(
                    chips,
                    { autoAlpha: 0, y: 8 },
                    {
                        autoAlpha: 1,
                        y: 0,
                        duration: 0.35,
                        delay: 0.35,
                        stagger: 0.05,
                        ease: 'power2.out',
                    }
                );
            }
            if (highlights.length) {
                gsap.fromTo(
                    highlights,
                    { autoAlpha: 0, x: -6 },
                    {
                        autoAlpha: 1,
                        x: 0,
                        duration: 0.35,
                        delay: 0.45,
                        stagger: 0.07,
                        ease: 'power2.out',
                    }
                );
            }
        };

        const showDetail = (i: number) => {
            if (isAnimating) return;
            const panel = detailPanels[i];
            if (!panel || !listView || !detailView) return;
            isAnimating = true;

            const tl = gsap.timeline({
                onComplete: () => {
                    isAnimating = false;
                },
            });

            // 1. Fade list out
            tl.to(listView, {
                autoAlpha: 0,
                y: -12,
                duration: 0.35,
                ease: 'power2.in',
            });
            tl.set(listView, { pointerEvents: 'none' });

            // 2. Reveal detail container + the selected panel shell
            tl.set(detailPanels, { autoAlpha: 0 });
            tl.set(detailView, { autoAlpha: 1, pointerEvents: 'auto' });
            tl.set(panel, { autoAlpha: 1 });

            // 3. Stagger internal content in
            tl.add(() => animateDetailIn(panel));
        };

        const showList = () => {
            if (isAnimating) return;
            if (!listView || !detailView) return;
            isAnimating = true;

            const tl = gsap.timeline({
                onComplete: () => {
                    activeIndex = null;
                    hoveredCountry = null;
                    isAnimating = false;
                },
            });

            // 1. Fade detail out
            tl.to(detailView, {
                autoAlpha: 0,
                y: 12,
                duration: 0.35,
                ease: 'power2.in',
            });
            tl.set(detailView, { pointerEvents: 'none', y: 0 });
            tl.set(detailPanels, { autoAlpha: 0 });

            // 2. Fade list back in
            tl.set(listView, { pointerEvents: 'auto' });
            tl.fromTo(
                listView,
                { autoAlpha: 0, y: -12 },
                {
                    autoAlpha: 1,
                    y: 0,
                    duration: 0.45,
                    ease: 'power3.out',
                }
            );
        };

        listItems.forEach((item, i) => {
            const lat = parseFloat(item.dataset.lat || '0');
            const lng = parseFloat(item.dataset.lng || '0');
            const countryName = item.dataset.country || '';

            item.addEventListener('click', () => {
                if (isAnimating) return;
                activeIndex = i;
                showDetail(i);
                applyCountryRotation(lat, lng, true);
                hoveredCountry = countryName;

                if (!hintDismissed && experienceHint) {
                    hintDismissed = true;
                    gsap.to(experienceHint, {
                        autoAlpha: 0,
                        duration: 0.3,
                        ease: 'power2.out',
                    });
                }
            });
        });

        backButtons.forEach((btn) => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                showList();
            });
        });

        // ============================================
        // RENDER LOOP (gated by IntersectionObserver + active-scroll pause for perf)
        // ============================================
        let isVisible = false;
        // Pauses the globe's render work while the user is actively scrolling.
        // The background Canvas.astro scene is frame-rate-locked (fixed `time +=`
        // increment per frame) and its scroll-triggered scrub callbacks fight for
        // main-thread budget. Skipping this loop during scroll hands those frames
        // back so the dev-object animation stays smooth. Resumes ~120ms after the
        // last scroll event.
        let isScrolling = false;
        let scrollIdleTimer: number | null = null;
        window.addEventListener(
            'scroll',
            () => {
                isScrolling = true;
                if (scrollIdleTimer !== null) window.clearTimeout(scrollIdleTimer);
                scrollIdleTimer = window.setTimeout(() => {
                    isScrolling = false;
                }, 120);
            },
            { passive: true }
        );
        const observer = new IntersectionObserver(
            (entries) => {
                isVisible = entries[0].isIntersecting;
            },
            { threshold: 0.01 }
        );
        observer.observe(section);

        // ============================================
        // MOUSE HOVER (raycaster against the InstancedMesh → scale nearby instances)
        // ============================================
        const raycaster = new THREE.Raycaster();
        const mouseNDC = new THREE.Vector2();
        let mouseOverCanvas = false;

        window.addEventListener('pointermove', (e) => {
            const rect = canvas.getBoundingClientRect();
            if (
                e.clientX < rect.left ||
                e.clientX > rect.right ||
                e.clientY < rect.top ||
                e.clientY > rect.bottom
            ) {
                mouseOverCanvas = false;
                return;
            }
            mouseOverCanvas = true;
            mouseNDC.x = ((e.clientX - rect.left) / rect.width) * 2 - 1;
            mouseNDC.y = -((e.clientY - rect.top) / rect.height) * 2 + 1;
        });

        const animDummy = new THREE.Object3D();
        const HOVER_RADIUS_3D = 0.12;
        const HOVER_SCALE_MULT = 2.6;

        const _brightColor = new THREE.Color();

        function animate() {
            requestAnimationFrame(animate);
            if (!isVisible) return;
            if (isScrolling && !gsap.isTweening(globeGroup.rotation) && !gsap.isTweening(globeGroup.position) && !gsap.isTweening(globeGroup.scale)) return;

            const t = performance.now() * 0.001;

            // Animate the strong golden light — mirrors updateDynamicLights() in Canvas.astro
            const lightSpeed = 0.1;
            const lightRadius = 1.5;
            spotLightFg.position.x = 2 + Math.cos(t * lightSpeed) * lightRadius;
            spotLightFg.position.y = 2 + Math.sin(t * lightSpeed * 0.7) * 0.8;
            spotLightFg.position.z = 8 + Math.sin(t * lightSpeed) * lightRadius;
            spotLightFg.intensity = 2.5 + Math.sin(t * 0.15) * 0.3;

            // Raycast hover: bump targetScale AND targetBrightness of nearby instances.
            if (globeMesh && mouseOverCanvas) {
                raycaster.setFromCamera(mouseNDC, camera);
                const hits = raycaster.intersectObject(globeMesh, false);
                if (hits.length > 0 && hits[0].instanceId !== undefined) {
                    const hitId = hits[0].instanceId;
                    const hitPos = globeInstances[hitId].basePos;
                    const r2 = HOVER_RADIUS_3D * HOVER_RADIUS_3D;
                    for (let i = 0; i < globeInstances.length; i++) {
                        const d = globeInstances[i];
                        const dx = d.basePos.x - hitPos.x;
                        const dy = d.basePos.y - hitPos.y;
                        const dz = d.basePos.z - hitPos.z;
                        const distSq = dx * dx + dy * dy + dz * dz;
                        if (distSq < r2) {
                            const falloff = 1 - distSq / r2;
                            const boosted = d.baseScale * (1 + (HOVER_SCALE_MULT - 1) * falloff);
                            if (boosted > d.targetScale) d.targetScale = boosted;
                            // Brightness boost matching Canvas.astro hover effect
                            const brightBoost = 1 + falloff * falloff * 0.8;
                            if (brightBoost > d.targetBrightness) d.targetBrightness = brightBoost;
                        }
                    }
                }
            }

            // Country hover pass (spotlight dim + country pulse).
            // Runs before the per-instance lerp so fresh targets are set each frame
            // while the highlight is active.
            const countryBreath = 1 + Math.sin(t * 4.5) * 0.12; // cinematic pulse
            const COUNTRY_SCALE_MULT = 1.5;
            const COUNTRY_BRIGHT_MULT = 1.6;
            const COUNTRY_DIM = 0.2;
            if (hoveredCountry && globeMesh) {
                for (let i = 0; i < globeInstances.length; i++) {
                    const d = globeInstances[i];
                    if (d.countryName === hoveredCountry) {
                        const tgtScale = d.baseScale * COUNTRY_SCALE_MULT * countryBreath;
                        if (tgtScale > d.targetScale) d.targetScale = tgtScale;
                        if (COUNTRY_BRIGHT_MULT > d.targetBrightness) d.targetBrightness = COUNTRY_BRIGHT_MULT;
                    } else {
                        if (COUNTRY_DIM < d.targetBrightness) d.targetBrightness = COUNTRY_DIM;
                    }
                }
            }

            // Per-instance update: rotation, radial float, scale lerp, brightness lerp.
            let colorNeedsUpdate = false;
            if (globeMesh) {
                for (let i = 0; i < globeInstances.length; i++) {
                    const d = globeInstances[i];
                    d.rotX += d.rotSpeedX;
                    d.rotY += d.rotSpeedY;
                    d.rotZ += d.rotSpeedZ;
                    d.currentScale += (d.targetScale - d.currentScale) * 0.15;
                    d.targetScale += (d.baseScale - d.targetScale) * 0.06;

                    // Lerp brightness back to 1.0 when not hovered
                    const prevBrightness = d.currentBrightness;
                    d.currentBrightness += (d.targetBrightness - d.currentBrightness) * 0.2;
                    d.targetBrightness += (1.0 - d.targetBrightness) * 0.1;

                    if (Math.abs(d.currentBrightness - prevBrightness) > 0.001) {
                        _brightColor.copy(d.baseColor).multiplyScalar(d.currentBrightness);
                        globeMesh.setColorAt(i, _brightColor);
                        colorNeedsUpdate = true;
                    }

                    // Strictly outward pulse (never < 1) so the float never pushes particles inside the sphere.
                    let radial = 1 + (Math.sin(t * 0.6 + d.floatOffset) * 0.5 + 0.5) * 0.006;
                    if (hoveredCountry && d.countryName === hoveredCountry) {
                        // Extra outward breathing on highlighted country — strictly positive.
                        radial += (Math.sin(t * 4 + d.floatOffset) * 0.5 + 0.5) * 0.025;
                    }
                    animDummy.position.set(
                        d.basePos.x * radial,
                        d.basePos.y * radial,
                        d.basePos.z * radial
                    );
                    animDummy.rotation.set(d.rotX, d.rotY, d.rotZ);
                    animDummy.scale.setScalar(d.currentScale);
                    animDummy.updateMatrix();
                    globeMesh.setMatrixAt(i, animDummy.matrix);
                }
                globeMesh.instanceMatrix.needsUpdate = true;
                if (colorNeedsUpdate && globeMesh.instanceColor) {
                    globeMesh.instanceColor.needsUpdate = true;
                }
            }

            renderer.render(scene, camera);
        }
        animate();

        // ============================================
        // RESIZE
        // ============================================
        const onResize = () => {
            const { width, height } = getSize();
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height, false);
            // Re-anchor the globe's resting X to the new viewport layout,
            // but don't fight GSAP mid-intro.
            if (!gsap.isTweening(globeGroup.position)) {
                globeGroup.position.x = computeRestingWorldX();
            }
        };
        window.addEventListener('resize', onResize);
        const ro = new ResizeObserver(onResize);
        ro.observe(canvas);
    }
</script>
